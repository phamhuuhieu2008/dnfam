@model List<Bảo_Tàng_Đà_Nẵng.Models.Question>
@{
    ViewData["Title"] = "Quản lý Câu hỏi";
}

<div class="page-wrapper animate-fadeInUp mt-24" style="max-width: 1000px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="section-title text-dark mb-0">Ngân hàng Câu hỏi</h2>
            <p class="section-subtitle mt-1">Danh sách tất cả câu hỏi trong hệ thống</p>
        </div>
        <div>
            <a asp-action="CreateQuestion" class="btn-primary-museum px-4 py-2 text-decoration-none mr-2" style="width: auto;">+ Thêm Câu Hỏi Mới</a>
            <a asp-action="Index" class="btn-secondary-museum px-4 py-2 text-decoration-none" style="width: auto;">Dashboard</a>
        </div>
    </div>

    @if (TempData["SuccessMsg"] != null)
    {
        <div class="alert alert-success mb-4" style="border-radius: 8px;">
            @TempData["SuccessMsg"]
        </div>
    }

    <div class="museum-card p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover mb-0" style="font-size: 0.9rem;">
                <thead style="background: rgba(10, 25, 47, 0.04);">
                    <tr>
                        <th class="px-4 py-3" style="width: 5%;">ID</th>
                        <th class="px-4 py-3" style="width: 35%;">Nội dung</th>
                        <th class="px-4 py-3">Đáp án đúng</th>
                        <th class="px-4 py-3">Điểm</th>
                        <th class="px-4 py-3">Địa điểm</th>
                        <th class="px-4 py-3 text-center">Trạng thái</th>
                        <th class="px-4 py-3 text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var q in Model)
                    {
                        <tr>
                            <td class="px-4 py-3 text-muted">#@q.Id</td>
                            <td class="px-4 py-3" style="color: var(--text-dark); font-weight: 500;">@q.Content</td>
                            <td class="px-4 py-3 text-center">
                                <span class="rank-badge gold d-inline-flex" style="width: 24px; height: 24px; font-size: 0.8rem;">@q.CorrectOption</span>
                            </td>
                            <td class="px-4 py-3" style="color: var(--primary);">@q.Points</td>
                            <td class="px-4 py-3 text-muted">@q.LocationName</td>
                            <td class="px-4 py-3 text-center">
                                @if(q.IsActive) { <span class="badge" style="background: var(--success); color: white; padding: 4px 8px; border-radius: 4px;">Hoạt động</span> }
                                else { <span class="badge" style="background: var(--error); color: white; padding: 4px 8px; border-radius: 4px;">Ẩn</span> }
                            </td>
                            <td class="px-4 py-3 text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="EditQuestion" asp-route-id="@q.Id" class="btn btn-sm btn-outline-primary" style="font-size: 0.8rem; padding: 2px 8px;">✏️ Sửa</a>
                                    <form asp-action="ToggleQuestionStatus" asp-route-id="@q.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(q.IsActive ? "btn-outline-danger" : "btn-outline-success")" style="font-size: 0.8rem; padding: 2px 8px;" onclick="return confirm('Bạn có chắc muốn @(q.IsActive ? "ẩn" : "hiện") câu hỏi này?');">
                                            @(q.IsActive ? "👁️‍🗨️ Ẩn" : "👁️ Hiện")
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
