<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=1.0" />
    <meta name="theme-color" content="#0A192F" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="description" content="Giải Mã Di Sản — Trải nghiệm quiz khám phá di sản lịch sử Đà Nẵng" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")Giải Mã Di Sản</title>
    <!-- Bootstrap 5 & FontAwesome -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" integrity="sha512-z3gLpd7yknf1YoNbCzqRKc4qyor8gaKU1qmn+CShxbuBusANI9QpRohGBreCFkKxLhei6S9CQXFEbbKuqLg0DA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <!-- Museum Design System -->
    <link rel="stylesheet" href="~/css/museum.css" asp-append-version="true" />
    
    <!-- Google Fonts cho giao diện Dark Luxury -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet">

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Ambient Background Orbs -->
    <div class="ambient-orb orb-1"></div>
    <div class="ambient-orb orb-2"></div>

    @* Chỉ hiển thị Navbar khi không phải trang Auth *@
    @if (ViewData["HideNav"] == null || !(bool)ViewData["HideNav"]!)
    {
        <nav class="navbar-museum">
            <div class="container d-flex justify-content-between align-items-center px-4">
                <a class="navbar-brand text-decoration-none" asp-controller="Home" asp-action="Index">
                    🏛️ GIẢI MÃ DI SẢN
                </a>
                <div class="nav-user">
                    @if (Context.Session.GetString("UserFullName") != null)
                    {
                        if (Context.Session.GetString("UserRole") == "Admin")
                        {
                            <a asp-controller="Admin" asp-action="Index"
                               style="color:var(--gold-light);font-size:0.85rem;font-weight:600;margin-right:12px;text-decoration:none">
                                ⚙️ Quản trị
                            </a>
                        }
                        <span class="score-badge mr-2">
                            ⭐ @(Context.Session.GetInt32("CurrentScore") ?? 0) điểm
                        </span>
                        <a asp-controller="Auth" asp-action="Logout"
                           style="color:var(--text-muted);font-size:0.82rem;text-decoration:none; margin-left: 10px;">
                            Thoát
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Login"
                           style="color:var(--gold-light);font-size:0.88rem;font-weight:600;text-decoration:none">
                            Đăng nhập
                        </a>
                    }
                </div>
            </div>
        </nav>
    }

    <div class="app-container">
        @RenderBody()
    </div>
    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
