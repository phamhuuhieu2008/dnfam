@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="page-wrapper animate-fadeInUp mt-24">
    <div class="museum-card form-wrapper">
        <h2 class="section-title text-dark">Đổi mật khẩu</h2>
        <p class="section-subtitle">Đảm bảo tài khoản của bạn luôn an toàn</p>

        <form asp-controller="Auth" asp-action="ChangePassword" method="post" id="changePwdForm">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert-museum error" id="summaryError"
                 style="display:none"></div>

            <div class="form-group">
                <label class="form-label" asp-for="CurrentPassword">Mật khẩu hiện tại</label>
                <input asp-for="CurrentPassword" class="form-input"
                       type="password" autocomplete="current-password" />
                <span asp-validation-for="CurrentPassword" class="form-validation-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="NewPassword">Mật khẩu mới</label>
                <input asp-for="NewPassword" class="form-input"
                       type="password" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="form-validation-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="ConfirmNewPassword">Xác nhận mật khẩu mới</label>
                <input asp-for="ConfirmNewPassword" class="form-input"
                       type="password" autocomplete="new-password" />
                <span asp-validation-for="ConfirmNewPassword" class="form-validation-error"></span>
            </div>

            <div class="mt-24">
                <button type="submit" id="btnSave" class="btn-primary-museum">
                    Lưu mật khẩu mới
                </button>
            </div>
            
            <div class="mt-16 text-center">
                <a asp-controller="Home" asp-action="Index" class="text-muted" style="text-decoration:none;font-size:0.9rem">
                    Hủy bỏ
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
(function() {
    var summary = document.querySelector('#summaryError ul');
    if (summary && summary.children.length > 0) {
        document.getElementById('summaryError').style.display = 'flex';
    }

    var form = document.getElementById('changePwdForm');
    var btn  = document.getElementById('btnSave');
    form.addEventListener('submit', function() {
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner"></span>&nbsp; Đang xử lý...';
    });
})();
</script>
}
