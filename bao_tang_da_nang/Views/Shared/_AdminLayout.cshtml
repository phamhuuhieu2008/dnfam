<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " - " : "")Admin Dashboard</title>
    <!-- Bootstrap 5 & FontAwesome -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

    <!-- Museum Design System -->
    <link rel="stylesheet" href="~/css/quizkid.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/museum.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-deep: #FAF8F5;
            --text-main: #2C1E0A;
            --glass-bg: #FFFFFF;
            --glass-border: #EFECE6;
            --gold-primary: #805A12;
            --gold-light: #FDF6EA;
            --brand-orange: #E07A3F;
        }
        body {
            background-color: var(--bg-deep);
            color: var(--text-main);
        }
        #admin-wrapper {
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
        }
        #sidebar {
            min-width: 260px;
            max-width: 260px;
            background: var(--glass-bg);
            backdrop-filter: var(--glass-blur);
            border-right: 1px solid var(--glass-border);
            transition: all 0.3s;
            display: flex;
            flex-direction: column;
            z-index: 1000;
        }
        #sidebar .sidebar-header {
            padding: 20px;
            text-align: center;
            border-bottom: 1px solid var(--glass-border);
        }
        #sidebar .sidebar-header h3 {
            color: var(--gold-primary);
            font-size: 1.4rem;
            margin: 0;
            font-family: var(--font-heading);
            font-weight: 700;
        }
        #sidebar ul.components {
            padding: 20px 0;
            flex: 1;
        }
        #sidebar ul li a {
            padding: 14px 20px;
            display: block;
            color: var(--text-main);
            text-decoration: none;
            font-weight: 600;
            transition: 0.2s;
            font-size: 0.95rem;
        }
        #sidebar ul li a:hover, #sidebar ul li.active > a {
            background: rgba(212, 175, 55, 0.15);
            color: var(--gold-primary);
            border-right: 4px solid var(--gold-primary);
        }
        #sidebar ul li a i {
            margin-right: 12px;
            width: 20px;
            text-align: center;
            color: var(--gold-light);
            font-size: 1.1rem;
        }
        #sidebar ul li.active > a i {
            color: var(--gold-primary);
        }
        #content {
            width: 100%;
            padding: 30px;
            min-height: 100vh;
            transition: all 0.3s;
            background-color: var(--bg-deep);
        }
        /* Navbar in content for mobile */
        .admin-navbar {
            background: var(--glass-bg);
            padding: 15px 20px;
            margin: -30px -30px 25px -30px;
            display: none; /* hidden on desktop */
            border-bottom: 1px solid var(--glass-border);
            box-shadow: var(--glass-shadow);
        }
        
        @@media (max-width: 768px) {
            #sidebar {
                margin-left: -260px;
                position: fixed;
                height: 100vh;
            }
            #sidebar.active {
                margin-left: 0;
            }
            .admin-navbar {
                display: flex;
                justify-content: space-between;
                align-items: center;
            }
            #content {
                padding: 15px;
            }
            .admin-navbar {
                margin: -15px -15px 20px -15px;
            }
            /* Dark overlay when sidebar is active */
            .overlay {
                display: none;
                position: fixed;
                width: 100vw;
                height: 100vh;
                background: rgba(0, 0, 0, 0.6);
                z-index: 999;
                backdrop-filter: blur(2px);
            }
            .overlay.active {
                display: block;
            }
        }

        /* Admin Form Khaki Theme */
        .form-control.auth-input, .form-select.auth-input {
            background-color: #9C9482 !important;
            color: #111 !important;
            border: none !important;
            border-radius: 8px !important;
            padding: 12px 16px !important;
        }
        .form-control.auth-input::placeholder {
            color: #444 !important;
        }
        .form-control.auth-input:focus, .form-select.auth-input:focus {
            outline: 2px solid #555 !important;
            box-shadow: none !important;
        }
        .form-label {
            color: #333 !important;
            font-weight: 500 !important;
            font-size: 0.95rem;
        }
        .text-danger {
            color: #D93025 !important;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="ambient-orb orb-1"></div>
    <div class="ambient-orb orb-2"></div>
    
    <div class="overlay" id="overlay"></div>
    <div id="admin-wrapper">
        <!-- Sidebar -->
        <nav id="sidebar">
            <div class="sidebar-header">
                <a href="/" class="text-decoration-none">
                    <img src="~/images/dnfam.png" alt="Bảo Tàng Đà Nẵng" style="max-height: 50px; object-fit: contain;" />
                </a>
            </div>

            <ul class="list-unstyled components">
                @{
                    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
                }
                <li class="@(currentAction == "Index" ? "active" : "")">
                    <a asp-controller="Admin" asp-action="Index"><i class="fa-solid fa-chart-pie"></i> Tổng quan</a>
                </li>
                <li class="@(currentAction == "Questions" ? "active" : "")">
                    <a asp-controller="Admin" asp-action="Questions"><i class="fa-solid fa-layer-group"></i> Danh sách Câu hỏi</a>
                </li>
                <li class="@(currentAction == "Users" ? "active" : "")">
                    <a asp-controller="Admin" asp-action="Users"><i class="fa-solid fa-user-shield"></i> Quản lý Người dùng</a>
                </li>
            </ul>
            <div style="padding: 20px;">
                <a asp-controller="Home" asp-action="Index" class="btn-secondary-museum w-100 mb-3 py-2" style="font-size: 0.9rem;">
                    <i class="fa-solid fa-house me-1"></i> Trang chủ
                </a>
                <a asp-controller="Auth" asp-action="Logout" class="btn-primary-museum w-100 py-2" style="font-size: 0.9rem; background: var(--error); border-color: var(--error); color: white !important;">
                    <i class="fa-solid fa-right-from-bracket me-1"></i> Đăng xuất
                </a>
            </div>
        </nav>

        <!-- Page Content -->
        <div id="content">
            <div class="admin-navbar">
                <button type="button" id="sidebarCollapse" class="btn" style="background: var(--gold-light); color: #000; border: none; padding: 8px 12px; border-radius: 6px;">
                    <i class="fa-solid fa-bars fs-5"></i>
                </button>
                <div class="d-flex align-items-center">
                    <img src="~/lib/dnfam.png" alt="Logo" height="30" class="me-2" />
                    <span style="font-family: var(--font-heading); color: var(--gold-primary); font-weight: bold; font-size: 1.1rem;">Bảo tàng Mỹ thuật ĐN</span>
                </div>
            </div>

            @RenderBody()
        </div>
    </div>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var sidebarCollapse = document.getElementById('sidebarCollapse');
            var sidebar = document.getElementById('sidebar');
            var overlay = document.getElementById('overlay');

            if(sidebarCollapse) {
                sidebarCollapse.addEventListener('click', function () {
                    sidebar.classList.toggle('active');
                    overlay.classList.toggle('active');
                });
            }
            if(overlay) {
                overlay.addEventListener('click', function () {
                    sidebar.classList.remove('active');
                    overlay.classList.remove('active');
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>