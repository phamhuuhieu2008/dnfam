                                    </div>
                                    <div class="stat-card"
                                         style="background: rgba(255,255,255,0.8); border: 1px solid rgba(212, 175, 55, 0.4); border-radius: 16px; padding: 15px 25px; min-width: 140px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                                        <div class="stat-number" style="font-size: 1.8rem; font-weight: 800; color: #27AE60;">
                                            @((object)(ViewBag.UserStats?.WinRate ?? 0))%</div>
                                            <div class="stat-label"
                                                 style="font-size: 0.85rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase;">
                                                Tỷ lệ trả lời đúng</div>
                                            </div>
                                            <div class="stat-card"
                                                 style="background: rgba(255,255,255,0.8); border: 1px solid rgba(212, 175, 55, 0.4); border-radius: 16px; padding: 15px 25px; min-width: 140px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                                                <div class="stat-number text-primary"
                                                     style="font-size: 1.8rem; font-weight: 800; color: var(--gold-light);">@((ViewBag.UserStats?.Rank >
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           0) ? $"Top {ViewBag.UserStats.Rank}" : "-")</div>
                                                    <div class="stat-label"
                                                         style="font-size: 0.85rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase;">
                                                        Xếp hạng hiện tại</div>
                                                    </div>
                                                    <div class="stat-card"
                                                         style="background: rgba(255,255,255,0.8); border: 1px solid rgba(212, 175, 55, 0.4); border-radius: 16px; padding: 15px 25px; min-width: 140px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                                                        <div class="stat-number" style="font-size: 1.8rem; font-weight: 800; color: #E67E22;">
                                                            @(ViewBag.UserStats?.TotalScore ?? 0)</div>
                                                            <div class="stat-label"
                                                                 style="font-size: 0.85rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase;">
                                                                Điểm tích lũy</div>
                                                            </div>
                                                        </div>

                                                        <div class="d-flex justify-content-center gap-3 mt-4 flex-wrap">
                                                            <a href="#topicSection" class="btn-primary-museum px-5 py-3 text-decoration-none"
