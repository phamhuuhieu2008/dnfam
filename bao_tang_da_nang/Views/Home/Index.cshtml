                                                            <span class="text-muted" style="font-size:0.9rem; font-weight: 500;">
                                                                💡 Bạn không cần tài khoản — chỉ chọn chủ đề và nhập tên để bắt đầu.
                                                            </span>
                                                        </div>
                                                    }
        else
