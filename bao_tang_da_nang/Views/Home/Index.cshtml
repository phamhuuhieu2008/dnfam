@section Styles {
    <style>
        /* Hiệu ứng 3D cho các cột danh mục (Pillar 3D) */
        .category-pillar-wrapper {
            perspective: 1000px;
            margin-bottom: 30px;
        }

        .category-pillar-3d {
            background: #ffffff;
            border-radius: 30px;
            padding: 40px 25px;
            height: 100%;
            position: relative;
            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            transform-style: preserve-3d;
            border: none !important;
            /* Tạo độ dày 3D ở đáy */
            box-shadow:
                0 15px 0 var(--pillar-depth),
                0 25px 40px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            align-items: center;
        }

        .category-pillar-wrapper:hover .category-pillar-3d {
            transform: translateY(-15px) rotateX(8deg);
            box-shadow:
                0 30px 0 var(--pillar-depth),
                0 40px 60px rgba(0, 0, 0, 0.15);
        }

        .pillar-icon-3d {
            font-size: 4.5rem;
            margin-bottom: 25px;
            filter: drop-shadow(0 10px 10px rgba(0, 0, 0, 0.1));
            transition: transform 0.4s ease;
        }

        .category-pillar-wrapper:hover .pillar-icon-3d {
            transform: translateZ(50px) scale(1.1);
        }

        .pillar-title {
            font-weight: 900 !important;
            font-size: 1.3rem !important;
            margin-bottom: 15px;
            color: var(--text-dark);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .pillar-btn {
            background: var(--gold-primary);
            color: white !important;
            padding: 12px 25px;
            border-radius: 50px;
            font-weight: 800;
            font-size: 0.9rem;
            box-shadow: 0 5px 15px rgba(212, 175, 55, 0.3);
            margin-top: 20px;
        }

        /* Responsive Hero Section & Content */
        @@media (max-width: 992px) {
            .hero-name {
                font-size: 2.2rem !important;
            }
        }

        @@media (max-width: 768px) {
            .hero-section {
                padding: 30px 15px !important;
                border-radius: 15px !important;
            }

            .hero-name {
                font-size: 1.8rem !important;
            }

            .hero-tagline {
                font-size: 1rem !important;
            }

            .stat-card {
                flex: 1 1 calc(50% - 10px) !important;
                min-width: 120px !important;
                padding: 12px !important;
            }

            .stat-number {
                font-size: 1.3rem !important;
            }

            .section-title {
                font-size: 1.3rem !important;
            }

            .topic-grid {
                grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)) !important;
                gap: 15px !important;
            }

            .leaderboard-item {
                padding: 12px 10px !important;
            }
        }

        @@media (max-width: 480px) {
            .hero-name {
                font-size: 1.5rem !important;
            }

            .stat-card {
                flex: 1 1 100% !important;
            }
        }
    </style>
}

<div class="page-wrapper animate-fadeInUp">

    <div class="hero-section mb-16"
         style="border: 1px solid rgba(212, 175, 55, 0.3); background: linear-gradient(145deg, rgba(139, 30, 25, 0.05) 0%, rgba(212, 175, 55, 0.1) 100%); padding: 40px 24px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
        @if (!string.IsNullOrWhiteSpace(fullName))
        {
            <div class="hero-greeting"
                 style="color: var(--gold-primary); font-weight: 700; font-size: 1.1rem; letter-spacing: 2px; text-transform: uppercase;">
                HỆ THỐNG THI TRẮC NGHIỆM TRỰC TUYẾN</div>
                <h1 class="hero-name"
                    style="color: var(--gold-primary); font-size: 2.8rem; font-weight: 800; margin: 10px 0 15px 0;">THÍ SINH:
                    @fullName</h1>
                    <p class="hero-tagline mb-4"
                       style="color: var(--text-muted); font-size: 1.15rem; max-width: 600px; margin-left: auto; margin-right: auto;">
                        Hãy chọn bộ đề thi dưới đây để thử thách kiến thức, rèn luyện tư duy và chinh phục vị trí dẫn đầu trên Bảng
                        vàng trắc nghiệm!</p>

