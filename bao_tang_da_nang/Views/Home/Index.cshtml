                                                                </div>
                                                            }

                                                            <div class="mt-24 mb-24 text-start">
                                                                <h2 class="section-title mb-1" style="font-size:1.4rem; text-align:left; font-weight: 700;">Quy chế & Thể lệ thi
                                                                    trắc nghiệm</h2>
                                                                    <p class="section-subtitle mb-4" style="text-align:left;">Thông tin cần biết trước khi bắt đầu thử thách</p>

                                                                    <div class="row g-4">
                                                                        <div class="col-md-4">
                                                                            <div class="museum-card p-4 h-100"
                                                                                 style="background: rgba(255,255,255,0.6); border: 1px solid rgba(212, 175, 55, 0.3);">
                                                                                <div style="font-size: 2.2rem; color: var(--gold-primary); margin-bottom: 15px;">⏱️</div>
                                                                                <h3 style="font-size: 1.15rem; font-weight: 700; color: var(--text-dark); margin-bottom: 10px;">Cấu
                                                                                    trúc Bộ Đề</h3>
                                                                                    <p style="font-size: 0.95rem; color: var(--text-muted); margin: 0; line-height: 1.5;">Mỗi bộ đề thi
                                                                                        gồm các câu hỏi trắc nghiệm được chọn lọc ngẫu nhiên từ ngân hàng đề thi chính thức của Bảo
                                                                                        tàng.</p>
                                                                                    </div>
                                                                                </div>
                                                                                <div class="col-md-4">
                                                                                    <div class="museum-card p-4 h-100"
                                                                                         style="background: rgba(255,255,255,0.6); border: 1px solid rgba(212, 175, 55, 0.3);">
                                                                                        <div style="font-size: 2.2rem; color: #27AE60; margin-bottom: 15px;">🎯</div>
                                                                                        <h3 style="font-size: 1.15rem; font-weight: 700; color: var(--text-dark); margin-bottom: 10px;">Chấm
                                                                                            Điểm & Thưởng</h3>
                                                                                            <p style="font-size: 0.95rem; color: var(--text-muted); margin: 0; line-height: 1.5;">Mỗi câu trả
                                                                                                lời đúng sẽ mang lại điểm thưởng tương ứng. Trả lời càng nhanh và chính xác, điểm tích lũy càng
                                                                                                cao.</p>
                                                                                            </div>
                                                                                        </div>
                                                                                        <div class="col-md-4">
                                                                                            <div class="museum-card p-4 h-100"
                                                                                                 style="background: rgba(255,255,255,0.6); border: 1px solid rgba(212, 175, 55, 0.3);">
                                                                                                <div style="font-size: 2.2rem; color: #E67E22; margin-bottom: 15px;">🏆</div>
                                                                                                <h3 style="font-size: 1.15rem; font-weight: 700; color: var(--text-dark); margin-bottom: 10px;">Bảng
                                                                                                    vàng Vinh danh</h3>
                                                                                                    <p style="font-size: 0.95rem; color: var(--text-muted); margin: 0; line-height: 1.5;">Hệ thống tự
                                                                                                        động xếp hạng thí sinh theo thời gian thực dựa trên tổng điểm tích lũy đạt được qua các lần thi.
                                                                                                    </p>
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>

