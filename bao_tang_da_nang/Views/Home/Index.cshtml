                                                            NỀN TẢNG THI TRẮC NGHIỆM TRỰC TUYẾN</div>
                                                            <h1 class="hero-name"
                                                                style="color: var(--gold-primary); font-size: 3.5rem; font-weight: 800; margin: 15px 0 20px 0; line-height: 1.2;">
                                                                Khám Phá Di Sản, Chinh Phục Tri Thức</h1>
                                                                <p class="hero-tagline mb-4"
                                                                   style="color: var(--text-muted); font-size: 1.2rem; max-width: 700px; margin-left: auto; margin-right: auto;">
                                                                    Hệ thống thi trắc nghiệm tương tác giúp bạn kiểm tra kiến thức, khám phá các giá trị Văn hóa, Lịch sử và Hội
                                                                    họa xứ Quảng một cách đầy hứng khởi.</p>

                                                                    <img src="~/lib/dnfam.png" alt="Bảo tàng Mỹ thuật Đà Nẵng"
                                                                         style="width: 100%; max-width: 320px; height: auto; max-height: 150px; object-fit: contain; margin: 0 auto 35px auto; display: block; filter: drop-shadow(0 10px 20px rgba(139, 30, 25, 0.15));" />

                                                                    <div class="d-flex justify-content-center gap-3 flex-wrap">
                                                                        <a href="#topicSection" class="btn-primary-museum px-5 py-3 text-decoration-none"
                                                                           style="font-size: 1.1rem; font-weight: 700; border-radius: 30px; box-shadow: 0 8px 25px rgba(139, 30, 25, 0.3);">
                                                                            🚀 CHỌN CHỦ ĐỀ
                                                                        </a>
                                                                        <span class="btn-secondary-museum px-5 py-3"
                                                                              style="font-size: 1.1rem; font-weight: 700; border-radius: 30px; cursor: default;">
                                                                            ✍️ Nhập tên ở màn tiếp theo
                                                                        </span>
                                                                    </div>
                                                                }
                                                            </div>

                                                            @if (TempData["ErrorMessage"] != null)
                                                            {
                                                                <div class="alert-museum error mt-16 mb-16" style="border-radius: 12px;">
                                                                    <span>⚠️</span>
