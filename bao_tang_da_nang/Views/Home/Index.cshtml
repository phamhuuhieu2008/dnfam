                                                                                                         style="display: none; border-radius: 30px; border: none; background: transparent; box-shadow: none;">
                                                                                                        <div class="row g-5 px-4 justify-content-center">
                                                                                                            @for (int i = 0; i < mainCategories.Count; i++)
                                                                                                            {
                                                                                                                var mainCat = mainCategories[i];
                                                                                                                var categoryTitle = mainCat.Name.Contains(":") ? mainCat.Name.Split(':')[1].Trim() : mainCat.Name;
                                                                                                                var pillarColor = (i == 0 ? "#4CAF50" : (i == 1 ? "#D4AF37" : "#FF7043"));
                                                                                                                var depthColor = (i == 0 ? "#388E3C" : (i == 1 ? "#B8860B" : "#E64A19"));

                                                                                                                <div class="col-lg-4 col-md-6 category-pillar-wrapper">
                                                                                                                    <a asp-controller="Quiz" asp-action="BrowseCategory" asp-route-id="@i"
                                                                                                                       class="text-decoration-none h-100 d-block">
                                                                                                                        <div class="category-pillar-3d" style="--pillar-depth: @depthColor;">
                                                                                                                            <div class="pillar-content">
                                                                                                                                <div class="pillar-icon-3d">
                                                                                                                                    @(i == 0 ? "🌿" : (i == 1 ? "📜" : "🏛️"))
                                                                                                                                </div>
                                                                                                                                <h3 class="pillar-title" style="color: @pillarColor;">@categoryTitle</h3>
                                                                                                                                <p class="text-muted" style="font-size: 0.95rem; font-weight: 500;">@mainCat.Description</p>
                                                                                                                            </div>
                                                                                                                            <div class="pillar-btn" style="background: @pillarColor;">
                                                                                                                                BẮT ĐẦU KHÁM PHÁ <i class="fa-solid fa-rocket ms-2"></i>
                                                                                                                            </div>
                                                                                                                        </div>
                                                                                                                    </a>
                                                                                                                </div>
                                                                                                            }
                                                                                                        </div>
                                                                                                    </div>
                                                                                                    <div class="mt-24 mb-24">
                                                                                                        <div class="d-flex justify-content-between align-items-end mb-3 flex-wrap gap-2">
                                                                                                            <div>
                                                                                                                <h2 class="section-title mb-1" style="font-size:1.5rem; text-align:left; font-weight: 800;">Bảng Vàng
                                                                                                                    Thành Tích Trắc Nghiệm</h2>
                                                                                                                    <p class="section-subtitle mb-0" style="text-align:left;">Top thí sinh có tổng điểm trắc nghiệm cao nhất
                                                                                                                        toàn hệ thống</p>
                                                                                                                    </div>
                                                                                                                    <div style="font-size: 1.8rem;">🏆</div>
                                                                                                                </div>

                                                                                                                <div class="museum-card p-3"
                                                                                                                     style="border-radius: 20px; border: 1px solid rgba(212, 175, 55, 0.3); box-shadow: 0 14px 35px rgba(197, 160, 89, 0.2);">
                                                                                                                    @{
                                                                                                                        var leaderboard = ViewBag.Leaderboard as List<Bảo_Tàng_Đà_Nẵng.Controllers.PlayerRankViewModel>;
                                                                                                                        if (leaderboard != null && leaderboard.Count > 0)
                                                                                                                        {
                                                                                                                            int rank = 1;
                                                                                                                            foreach (var player in leaderboard)
                                                                                                                            {
                                                                                                                                string badgeClass = rank == 1 ? "gold" : (rank == 2 ? "silver" : (rank == 3 ? "bronze" : "normal"));
                                                                                                                                <div class="leaderboard-item @($"top-{rank}") @(rank == leaderboard.Count ? "mb-0" : "")"
                                                                                                                                     style="display: flex; align-items: center; padding: 16px 20px; border-bottom: @(rank == leaderboard.Count ? "none" : "1px solid rgba(212, 175, 55, 0.15)"); transition: all 0.2s; border-radius: 12px;">
                                                                                                                                    <div class="rank-badge @badgeClass"
                                                                                                                                         style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; border-radius: 50%; font-weight: 800; font-size: 1.1rem; margin-right: 20px; background: @(rank == 1 ? "var(--gold-primary)" : (rank == 2 ? "#C0C0C0" : (rank == 3 ? "#CD7F32" : "rgba(10,25,47,0.05)"))); color: @(rank <= 3 ? "#FFF" : "var(--text-main)"); box-shadow: @(rank <= 3 ? "0 4px 10px rgba(0,0,0,0.15)" : "none");">
                                                                                                                                        @rank</div>
                                                                                                                                        <div style="flex: 1; text-align: left;">
                                                                                                                                            <div style="font-weight: 700; color: var(--text-dark); font-size: 1.15rem;">@player.FullName</div>
                                                                                                                                            <div style="font-size: 0.9rem; color: var(--gold-primary); font-weight: 600;">⭐ @player.TotalScore
                                                                                                                                                điểm trắc nghiệm</div>
                                                                                                                                            </div>
                                                                                                                                            @if (rank == 1)
                                                                                                                                            {
                                                                                                                                                <div style="font-size: 1.8rem; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));" title="Top 1 Quán Quân">
                                                                                                                                                    🏆 Quán Quân</div>
                                                                                                                                                }
                            else if (rank == 2)
                                                                                                                                                {
                                                                                                                                                    <div style="font-size: 1.8rem; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));" title="Top 2 Á Quân">🥈
                                                                                                                                                        Á Quân</div>
                                                                                                                                                    }
                            else if (rank == 3)
                                                                                                                                                    {
                                                                                                                                                        <div style="font-size: 1.8rem; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));" title="Top 3 Quý Quân">
                                                                                                                                                            🥉 Quý Quân</div>
                                                                                                                                                        }
                            else
                                                                                                                                                        {
                                                                                                                                                            <div style="font-size: 1.1rem; font-weight: 600; color: var(--text-muted);">Top @rank</div>
                                                                                                                                                        }
                                                                                                                                                    </div>
                                                                                                                                                    rank++;
                                                                                                                                                }
                                                                                                                                            }
                                                                                                                                            else
                                                                                                                                            {
                                                                                                                                                <div class="text-center text-muted py-5">
                                                                                                                                                    <div style="font-size: 3rem; margin-bottom: 10px;">🏆</div>
                                                                                                                                                    <h5 style="font-weight: 700; color: var(--text-dark);">Chưa có dữ liệu xếp hạng trắc nghiệm</h5>
                                                                                                                                                    <p style="color: var(--text-muted); margin: 0;">Hãy chọn một bộ đề thi ở trên và trở thành người đầu
                                                                                                                                                        tiên ghi danh lên Bảng vàng!</p>
                                                                                                                                                    </div>
                                                                                                                                                }
                                                                                                                                            }
                                                                                                                                        </div>
                                                                                                                                    </div>
                                                                                                                                </div>
                                                                                                                                @section Scripts {
                                                                                                                                    <script>
                                                                                                                                        document.addEventListener('DOMContentLoaded', function () {
                                                                                                                                            const searchInput = document.getElementById('categorySearchInput'); // From Navbar
                                                                                                                                            const navCategoryFilter = document.getElementById('navCategoryFilter'); // From Navbar
                                                                                                                                            const topicCards = document.querySelectorAll('.topic-card-item');
                                                                                                                                            const noResultsMsg = document.getElementById('noResultsMessage');
                                                                                                                                            const countBadge = document.getElementById('categoryCountBadge');

                                                                                                                                            function performFilter() {
                                                                                                                                                const query = searchInput ? searchInput.value.trim().toLowerCase() : "";
                                                                                                                                                const currentSelectedCat = (navCategoryFilter && navCategoryFilter.value) || "";
                                                                                                                                                const categoryBlocks = document.querySelectorAll('.main-category-block');
                                                                                                                                                let totalVisible = 0;

                                                                                                                                                categoryBlocks.forEach(block => {
                                                                                                                                                    let visibleInBlock = 0;
                                                                                                                                                    const cards = block.querySelectorAll('.topic-card-item');

                                                                                                                                                    cards.forEach(card => {
                                                                                                                                                        const title = card.querySelector('.topic-card-title').textContent.toLowerCase();
                                                                                                                                                        const cardCat = card.getAttribute('href').split('topic=')[1];
                                                                                                                                                        const decodedCat = decodeURIComponent(cardCat || "");

                                                                                                                                                        const matchSearch = title.includes(query);
                                                                                                                                                        const matchCat = currentSelectedCat === "" || decodedCat === currentSelectedCat;

                                                                                                                                                        if (matchSearch && matchCat) {
                                                                                                                                                            card.style.display = 'block';
                                                                                                                                                            visibleInBlock++;
                                                                                                                                                            totalVisible++;
                                                                                                                                                        } else {
                                                                                                                                                            card.style.display = 'none';
                                                                                                                                                        }
                                                                                                                                                    });

                                                                                                                                                    // Ẩn toàn bộ khối danh mục nếu không có chủ đề nào bên trong khớp tìm kiếm
                                                                                                                                                    block.style.display = visibleInBlock > 0 ? 'block' : 'none';
                                                                                                                                                });

                                                                                                                                                if (countBadge) countBadge.textContent = totalVisible + ' bộ đề thi';
                                                                                                                                                if (noResultsMsg) noResultsMsg.style.display = totalVisible === 0 ? 'block' : 'none';
                                                                                                                                            }

                                                                                                                                            if (searchInput) {
                                                                                                                                                searchInput.addEventListener('input', performFilter);
                                                                                                                                            }

                                                                                                                                            // Initial filter when page loads
                                                                                                                                            performFilter();
                                                                                                                                        });
                                                                                                                                    </script>
                                                                                                                                }
