@{
    ViewData["Title"] = "Trang chủ - Quizz";
    var fullName = Context.Session.GetString("UserFullName");
    var categories = ViewBag.Categories as List<Bảo_Tàng_Đà_Nẵng.Controllers.CategorySummaryViewModel>;
    var leaderboard = ViewBag.Leaderboard as List<Bảo_Tàng_Đà_Nẵng.Controllers.PlayerRankViewModel>;

    // Default categories if none exist in DB (for safety)
    if (categories == null || categories.Count == 0)
    {
        categories = new List<Bảo_Tàng_Đà_Nẵng.Controllers.CategorySummaryViewModel>
        {
            new Bảo_Tàng_Đà_Nẵng.Controllers.CategorySummaryViewModel { Name = "Chủ đề 1: Địa lý & Lịch sử Bảo tàng", QuestionCount = 75 },
            new Bảo_Tàng_Đà_Nẵng.Controllers.CategorySummaryViewModel { Name = "Chủ đề 2: Thiên nhiên & Con người", QuestionCount = 75 },
            new Bảo_Tàng_Đà_Nẵng.Controllers.CategorySummaryViewModel { Name = "Chủ đề 3: Địa chất & Hệ sinh thái biển", QuestionCount = 75 },
            new Bảo_Tàng_Đà_Nẵng.Controllers.CategorySummaryViewModel { Name = "Chủ đề 4: Tiền - Sơ sử & Sa Huỳnh", QuestionCount = 75 }
        };
    }

    // Helper function to map topics to our 4 main kid subjects
    string GetSubjectClass(string topicName)
    {
        var upper = topicName.ToUpper();
        if (upper.Contains("ĐỀ TÀI 1") || upper.Contains("CHỦ ĐỀ 1") || upper.Contains("ĐỊA LÝ")) return "science";
        if (upper.Contains("ĐỀ TÀI 2") || upper.Contains("CHỦ ĐỀ 2") || upper.Contains("THIÊN NHIÊN")) return "math";
        if (upper.Contains("ĐỀ TÀI 3") || upper.Contains("CHỦ ĐỀ 3") || upper.Contains("ĐỊA CHẤT")) return "languages";
        if (upper.Contains("ĐỀ TÀI 4") || upper.Contains("CHỦ ĐỀ 4") || upper.Contains("KHẢO CỔ") || upper.Contains("SA HUỲNH")) return "art";
        return "science";
    }

    var random = new Random();
    var randomCategories = categories
        .Where(c => !c.Name.Contains("Tổng hợp", StringComparison.OrdinalIgnoreCase) && c.Name != "Khác")
        .OrderBy(x => random.Next())
        .Take(3)
        .ToList();
}

@section Styles {
    <style>
        /* Specific page styles can go here if needed */
        .all-quizzes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 24px;
        }
        
        .no-results-kid {
            display: none;
            padding: 50px 20px;
            text-align: center;
            background-color: var(--white);
            border-radius: 24px;
            border: 2px dashed #EFECE6;
            margin: 30px 0;
        }

        /* Achievements Dashboard Styles */
        .dashboard-banner-kid {
            position: relative;
            background: linear-gradient(135deg, #C25927 0%, #A24214 100%);
            border-radius: 40px;
            padding: 40px;
            text-align: left;
            color: var(--white);
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(162, 66, 20, 0.25);
            border: 6px solid #FFF;
        }

        .dashboard-crown-badge {
            width: 54px;
            height: 54px;
            border-radius: 50%;
            background-color: rgba(255, 255, 255, 0.2);
            border: 2px solid rgba(255, 255, 255, 0.4);
            display: flex;
            justify-content: center;
            align-items: center;
            color: #FFD700;
            font-size: 1.6rem;
            animation: pulse-glow 2s infinite alternate;
        }

        @@keyframes pulse-glow {
            0% {
                box-shadow: 0 0 0 0 rgba(255, 215, 0, 0.4);
                transform: scale(1);
            }
            100% {
                box-shadow: 0 0 12px 6px rgba(255, 215, 0, 0.2);
                transform: scale(1.05);
            }
        }

        .dashboard-stat-card {
            background-color: var(--white);
            border-radius: 24px;
            border: 3px solid #EFECE6;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .dashboard-stat-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
            border-color: #D4AF37;
        }

        .stat-icon-wrapper {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 8px;
        }

        .dashboard-stat-value {
            font-family: var(--font-heading);
            font-weight: 800;
            font-size: 2.2rem;
            color: var(--text-main);
            line-height: 1.2;
        }

        .dashboard-stat-label {
            font-family: var(--font-heading);
            font-weight: 700;
            font-size: 0.85rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Circular chart styles */
        .circular-progress-wrapper {
            position: relative;
            width: 70px;
            height: 70px;
        }

        .circular-chart-svg {
            transform: rotate(-90deg);
        }

        .circle-progress-bar {
            transition: stroke-dasharray 1s ease-out;
        }

        .circle-percentage-text {
            font-family: var(--font-heading);
            font-weight: 800;
            font-size: 8px;
            text-anchor: middle;
            fill: var(--text-main);
            transform: rotate(90deg);
            transform-origin: center;
        }

        .dashboard-history-card {
            background-color: var(--white);
            border-radius: 28px;
            border: 3px solid #EFECE6;
            box-shadow: 0 10px 25px rgba(0,0,0,0.06);
            max-height: 320px;
        }

        .dashboard-panel-subheading {
            font-family: var(--font-heading);
            font-weight: 800;
            color: var(--text-main);
            font-size: 1.2rem;
            border-bottom: 2px dashed #EFECE6;
            padding-bottom: 10px;
        }

        .dashboard-history-scroll {
            overflow-y: auto;
            max-height: 220px;
            padding-right: 6px;
        }

        /* Scrollbar styling */
        .dashboard-history-scroll::-webkit-scrollbar {
            width: 6px;
        }
        .dashboard-history-scroll::-webkit-scrollbar-track {
            background: #FDFDFD;
            border-radius: 10px;
        }
        .dashboard-history-scroll::-webkit-scrollbar-thumb {
            background: #E0DCD5;
            border-radius: 10px;
        }
        .dashboard-history-scroll::-webkit-scrollbar-thumb:hover {
            background: #CBBFB1;
        }

        .dashboard-history-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .history-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            background-color: #FAF8F5;
            border-radius: 18px;
            border: 2px solid #F3F1EC;
            transition: all 0.2s ease;
        }

        .history-item:hover {
            transform: scale(1.01);
            background-color: #FFF;
            border-color: #EFECE6;
            box-shadow: 0 4px 10px rgba(0,0,0,0.04);
        }

        .history-item-badge {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 1.25rem;
            flex-shrink: 0;
        }

        .history-item-badge.science { background-color: #EAF6EC; color: #27AE60; }
        .history-item-badge.math { background-color: #FFF9E6; color: #D4AF37; }
        .history-item-badge.languages { background-color: #EAF2FA; color: #2F80ED; }
        .history-item-badge.art { background-color: #FAF0F4; color: #EB5757; }

        .history-item-info {
            flex-grow: 1;
            min-width: 0;
        }

        .history-item-topic {
            font-family: var(--font-heading);
            font-weight: 700;
            font-size: 0.95rem;
            color: var(--text-main);
            line-height: 1.3;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .history-item-date {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .history-item-score {
            text-align: right;
            flex-shrink: 0;
        }

        .score-value {
            font-family: var(--font-heading);
            font-weight: 800;
            font-size: 1rem;
            color: #C25927;
        }

        .score-accuracy {
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--text-muted);
        }

        /* Responsive Mobile Settings */
        @@media (max-width: 768px) {
            .dashboard-banner-kid {
                padding: 24px;
                border-radius: 24px;
            }
            .dashboard-stat-card {
                margin-bottom: 15px;
            }
            .dashboard-history-card {
                max-height: 400px;
            }
            .dashboard-history-scroll {
                max-height: 300px;
            }
        }
    </style>
}

<div class="page-wrapper animate-fadeInUp">
    <!-- Hero Section -->
    <section class="hero-kid container px-4">
        <div class="row align-items-center w-100 mx-0">
            <div class="col-lg-7 col-md-12 hero-kid-content">
                
                @if (!string.IsNullOrWhiteSpace(fullName))
                {
                    <h1 class="hero-kid-title"><span data-translate="hero_welcome">Chào mừng trở lại,</span><br><span class="brand-name">@fullName!</span></h1>
                    <p class="hero-kid-desc" data-translate="hero_welcome_desc">Cùng tiếp tục hành trình khám phá kho tàng kiến thức lịch sử, tự nhiên và nghệ thuật siêu thú vị. Bạn đã sẵn sàng bứt phá chưa?</p>
                    
                    <!-- Player Stats -->
                    <div class="kid-stats-row mb-4">
                        <div class="kid-stat-card">
                            <div class="kid-stat-number">@((object)(ViewBag.UserStats?.TotalPlayed ?? 0))</div>
                            <div class="kid-stat-label" data-translate="hero_stats_played">Số Đề Đã Thi</div>
                        </div>
                        <div class="kid-stat-card">
                            <div class="kid-stat-number" style="color: #27AE60;">@((object)(ViewBag.UserStats?.WinRate ?? 0))%</div>
                            <div class="kid-stat-label" data-translate="hero_stats_accuracy">Tỷ Lệ Đúng</div>
                        </div>
                        <div class="kid-stat-card">
                            <div class="kid-stat-number" style="color: #EB5757;">@((ViewBag.UserStats?.Rank > 0) ? $"Top {ViewBag.UserStats.Rank}" : "-")</div>
                            <div class="kid-stat-label" data-translate="hero_stats_rank">Hạng Của Bạn</div>
                        </div>
                        <div class="kid-stat-card">
                            <div class="kid-stat-number" style="color: #2F80ED;">@(ViewBag.UserStats?.TotalScore ?? 0)</div>
                            <div class="kid-stat-label" data-translate="hero_stats_score">Điểm Tích Lũy</div>
                        </div>
                    </div>
                }
                else
                {
                    <h1 class="hero-kid-title" data-translate="hero_title">Khám phá tri thức,<br>vui nhộn cùng <span class="brand-name">Quizz!</span></h1>
                    <p class="hero-kid-desc" data-translate="hero_desc">Hệ thống câu hỏi trắc nghiệm tương tác giúp các bạn nhỏ tìm hiểu về Lịch sử, Tự nhiên và Nghệ thuật một cách đầy hứng khởi.</p>
                }
            </div>
            <div class="col-lg-5 col-md-12 d-none d-lg-flex mascot-container">
                <div class="mascot-img-wrap">
                    <img src="~/images/quizkid_mascot.png" alt="QuizKid Mascot" class="mascot-img" />
                </div>
            </div>
        </div>
    </section>

    <!-- Subjects Categories Section -->
    <section class="subject-section container px-4 mb-4">
        <h2 class="section-kid-title" data-translate="subject_title">Tổng Hợp Câu Hỏi</h2>
        
        <div class="row g-4 mt-2">
            @foreach (var cat in categories)
            {
                string subjectType = GetSubjectClass(cat.Name);
                string iconClass = "fa-solid fa-layer-group";
                string cardClass = "science-card";
                
                if (subjectType == "math") { iconClass = "fa-solid fa-calculator"; cardClass = "math-card"; }
                else if (subjectType == "languages") { iconClass = "fa-solid fa-language"; cardClass = "languages-card"; }
                else if (subjectType == "art") { iconClass = "fa-solid fa-palette"; cardClass = "art-card"; }
                
                <div class="col-lg-3 col-md-6 col-sm-6">
                    <a asp-controller="Quiz" asp-action="StartSession" asp-route-topic="@cat.Name" class="text-decoration-none d-block h-100">
                        <div class="subject-card @cardClass h-100" data-subject="@subjectType">
                            <div class="subject-icon-box"><i class="@iconClass"></i></div>
                            <h3 class="subject-name" style="font-size: 1.1rem; line-height: 1.4;">@cat.Name.ToUpper()</h3>
                            <p class="subject-desc">@cat.QuestionCount câu hỏi</p>
                        </div>
                    </a>
                </div>
            }
        </div>
    </section>

    <!-- Featured Quizzes -->
    <section class="quiz-section container px-4">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <span class="section-kid-eyebrow" data-translate="featured_eyebrow">THỬ THÁCH ĐỀ XUẤT</span>
                <h2 class="section-kid-title mb-0" data-translate="featured_title">Các Bộ Quiz Nổi Bật</h2>
            </div>
        </div>
        
        <div class="row g-4">
            <!-- Featured 1: Science / Space -->
            <div class="col-lg-4 col-md-6">
                <div class="quiz-kid-card">
                    <div class="quiz-kid-card-img-wrap">
                        <span class="quiz-tag-difficulty medium" data-translate="difficulty_medium">Trung bình</span>
                        <div class="quiz-rating"><i class="fa-solid fa-star"></i> 4.9</div>
                        <img src="~/images/space_quiz.png" alt="Khám phá vũ trụ" class="quiz-kid-card-img" />
                    </div>
                    <div class="quiz-kid-card-body">
                        <div>
                            <h3 class="quiz-kid-card-title" data-translate="featured_science_title">Khám Phá Đại Dương & Sinh Thái</h3>
                            <p class="quiz-kid-card-desc" data-translate="featured_science_desc">Thám hiểm hệ sinh thái biển sâu và tìm hiểu sự đa dạng sinh học kỳ thú của tự nhiên.</p>
                        </div>
                        @{
                            var spaceCat = categories.FirstOrDefault(c => c.Name.Contains("Chủ đề 3", StringComparison.OrdinalIgnoreCase)) ?? categories.FirstOrDefault();
                        }
                        @if (spaceCat != null)
                        {
                            <a asp-controller="Quiz" asp-action="StartSession" asp-route-topic="@spaceCat.Name" class="btn-start-quiz" data-translate="play_now">
                                BẮT ĐẦU CHƠI <i class="fa-solid fa-play"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>
            
            <!-- Featured 2: Math / Archeology -->
            <div class="col-lg-4 col-md-6">
                <div class="quiz-kid-card">
                    <div class="quiz-kid-card-img-wrap">
                        <span class="quiz-tag-difficulty hard" data-translate="difficulty_hard">Khó</span>
                        <div class="quiz-rating"><i class="fa-solid fa-star"></i> 4.8</div>
                        <img src="~/images/tien-susahuynh.png" alt="Khảo cổ Sa Huỳnh" class="quiz-kid-card-img" />
                    </div>
                    <div class="quiz-kid-card-body">
                        <div>
                            <h3 class="quiz-kid-card-title" data-translate="featured_math_title">Bí Ẩn Khảo Cổ & Sơ Sử Sa Huỳnh</h3>
                            <p class="quiz-kid-card-desc" data-translate="featured_math_desc">Cùng những con số kỳ diệu giải mã bí mật của các cổ vật quý hiếm hàng ngàn năm tuổi.</p>
                        </div>
                        @{
                            var mathCat = categories.FirstOrDefault(c => c.Name.Contains("Chủ đề 4", StringComparison.OrdinalIgnoreCase)) ?? categories.FirstOrDefault();
                        }
                        @if (mathCat != null)
                        {
                            <a asp-controller="Quiz" asp-action="StartSession" asp-route-topic="@mathCat.Name" class="btn-start-quiz" data-translate="play_now">
                                BẮT ĐẦU CHƠI <i class="fa-solid fa-play"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>
            
            <!-- Featured 3: Animals / Nature -->
            <div class="col-lg-4 col-md-6">
                <div class="quiz-kid-card">
                    <div class="quiz-kid-card-img-wrap">
                        <span class="quiz-tag-difficulty easy" data-translate="difficulty_easy">Dễ</span>
                        <div class="quiz-rating"><i class="fa-solid fa-star"></i> 5.0</div>
                        <img src="~/images/thien-nhien-va-con-nguoi.png" alt="Thiên nhiên động vật" class="quiz-kid-card-img" />
                    </div>
                    <div class="quiz-kid-card-body">
                        <div>
                            <h3 class="quiz-kid-card-title" data-translate="featured_art_title">Thiên Nhiên & Muông Thú</h3>
                            <p class="quiz-kid-card-desc" data-translate="featured_art_desc">Bước vào khu rừng xanh thẳm, làm quen với các loài động thực vật cực kỳ độc đáo.</p>
                        </div>
                        @{
                            var animalsCat = categories.FirstOrDefault(c => c.Name.Contains("Chủ đề 2", StringComparison.OrdinalIgnoreCase)) ?? categories.FirstOrDefault();
                        }
                        @if (animalsCat != null)
                        {
                            <a asp-controller="Quiz" asp-action="StartSession" asp-route-topic="@animalsCat.Name" class="btn-start-quiz" data-translate="play_now">
                                BẮT ĐẦU CHƠI <i class="fa-solid fa-play"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- All Quizzes Section -->
    <section class="quiz-section bg-light-kid pt-2 pb-5" id="allQuizzesSection">
        <div class="container px-4">
            <div class="mb-4 text-center">
                <span class="section-kid-eyebrow" data-translate="all_eyebrow">TẤT CẢ THỬ THÁCH</span>
                <h2 class="section-kid-title mb-0" data-translate="all_title">Kho Trắc Nghiệm Đa Dạng</h2>
            </div>
            
            <div class="all-quizzes-grid" id="quizzesGrid">
                @foreach (var cat in categories.Take(4))
                {
                    string subjectType = GetSubjectClass(cat.Name);
                    
                    string imageFile = "topic1.png";
                    
                    if (cat.Name.Contains("ĐỀ TÀI 2", StringComparison.OrdinalIgnoreCase) || cat.Name.Contains("Chủ đề 2", StringComparison.OrdinalIgnoreCase)) { imageFile = "topic2.png"; }
                    else if (cat.Name.Contains("ĐỀ TÀI 3", StringComparison.OrdinalIgnoreCase) || cat.Name.Contains("Chủ đề 3", StringComparison.OrdinalIgnoreCase)) { imageFile = "topic3.png"; }
                    else if (cat.Name.Contains("ĐỀ TÀI 4", StringComparison.OrdinalIgnoreCase) || cat.Name.Contains("Chủ đề 4", StringComparison.OrdinalIgnoreCase)) { imageFile = "topic4.png"; }
                    else if (cat.Name.Contains("ĐỀ TÀI 1", StringComparison.OrdinalIgnoreCase) || cat.Name.Contains("Chủ đề 1", StringComparison.OrdinalIgnoreCase)) { imageFile = "topic1.png"; }
                    else if (cat.Name.Contains("ĐỀ TÀI 5", StringComparison.OrdinalIgnoreCase) || cat.Name.Contains("Chủ đề 5", StringComparison.OrdinalIgnoreCase)) { imageFile = "topic5.png"; }
                    else if (cat.Name.Contains("ĐỀ TÀI 6", StringComparison.OrdinalIgnoreCase) || cat.Name.Contains("Chủ đề 6", StringComparison.OrdinalIgnoreCase)) { imageFile = "topic6.png"; }
                    else if (cat.Name.Contains("ĐỀ TÀI 7", StringComparison.OrdinalIgnoreCase) || cat.Name.Contains("Chủ đề 7", StringComparison.OrdinalIgnoreCase)) { imageFile = "topic7.png"; }
                    else if (cat.Name.Contains("ĐỀ TÀI 8", StringComparison.OrdinalIgnoreCase) || cat.Name.Contains("Chủ đề 8", StringComparison.OrdinalIgnoreCase)) { imageFile = "topic8.png"; }
                    else if (cat.Name.Contains("ĐỀ TÀI 9", StringComparison.OrdinalIgnoreCase) || cat.Name.Contains("Chủ đề 9", StringComparison.OrdinalIgnoreCase)) { imageFile = "topic9.png"; }
                    else if (cat.Name.Contains("ĐỀ TÀI 10", StringComparison.OrdinalIgnoreCase) || cat.Name.Contains("Chủ đề 10", StringComparison.OrdinalIgnoreCase)) { imageFile = "topic10.png"; }
                    else if (cat.Name.Contains("Tổng hợp", StringComparison.OrdinalIgnoreCase)) { imageFile = "topic_general.png"; }
                    else if (cat.Name.Contains("làng nghề", StringComparison.OrdinalIgnoreCase)) { imageFile = "topic_craft_village.png"; }
                    else if (cat.Name.Contains("Câu lạc bộ", StringComparison.OrdinalIgnoreCase)) { imageFile = "topic_club.png"; }
                    else if (cat.Name.Contains("Nghệ nhân", StringComparison.OrdinalIgnoreCase)) { imageFile = "topic_artisan.png"; }
                    else if (cat.Name.Contains("Tin tức", StringComparison.OrdinalIgnoreCase) || cat.Name.Contains("Sự kiện", StringComparison.OrdinalIgnoreCase)) { imageFile = "topic_news.png"; }
                    else 
                    {
                        int hash = 0;
                        for (int i = 0; i < cat.Name.Length; i++) hash = (hash * 31) + cat.Name[i];
                        hash = Math.Abs(hash) % 5;
                        string[] fallbacks = { "topic_general.png", "topic_craft_village.png", "topic_club.png", "topic_artisan.png", "topic_news.png" };
                        imageFile = fallbacks[hash];
                    }
                    
                    <div class="quiz-kid-card mini-topic-card" data-subject="@subjectType" data-title="@cat.Name.ToLower()">
                        <div class="quiz-kid-card-img-wrap" style="height: 160px; position: relative;">
                            @if(cat.IsCompleted)
                            {
                                <div style="position: absolute; top: 10px; right: 10px; background: #28a745; color: white; padding: 4px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: bold; z-index: 10; box-shadow: 0 2px 5px rgba(0,0,0,0.2);">
                                    <i class="fa-solid fa-check"></i> <span data-translate="completed">Đã hoàn thành</span>
                                </div>
                            }
                            <img src="~/images/topics/@imageFile" alt="@cat.Name" class="quiz-kid-card-img" style="object-fit: cover; height: 100%; width: 100%;" />
                        </div>
                        <div class="quiz-kid-card-body" style="padding: 20px;">
                            <h3 class="quiz-kid-card-title" style="font-size: 1.15rem !important;">
                                <span>@cat.Name</span>
                                @if(cat.IsCompleted)
                                {
                                    <i class="fa-solid fa-circle-check text-success" title="Đã hoàn thành" style="margin-left: 5px;" data-translate="completed" data-bs-toggle="tooltip"></i>
                                }
                            </h3>
                            <div style="font-size: 0.85rem; font-weight: 600; color: var(--text-muted); margin-bottom: 15px;">
                                📝 @cat.QuestionCount <span data-translate="questions_count">câu hỏi</span>
                            </div>
                            <a asp-controller="Quiz" asp-action="StartSession" asp-route-topic="@cat.Name" class="btn-start-quiz" style="padding: 10px 15px; font-size: 0.85rem;" data-translate="play_now_mini">
                                LÀM BÀI <i class="fa-solid fa-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                }
            </div>
            
            <div class="text-center mt-5 mb-2">
                <a asp-controller="Quiz" asp-action="Library" class="view-all-link" data-translate="show_all" style="font-size: 1.15rem;">Hiển thị tất cả <i class="fa-solid fa-arrow-right ms-2"></i></a>
            </div>

        </div>
    </section>
 
    <!-- Achievements & Play History Dashboard Section -->
    <section class="cta-section container px-4" id="achievementsDashboardSection">
        <div class="dashboard-banner-kid">
            <div class="row g-4 align-items-stretch" style="position: relative; z-index: 2;">
                <!-- Left Column: Key Stats Indicators -->
                <div class="col-lg-5 col-md-12 d-flex flex-column justify-content-between">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="dashboard-crown-badge">
                            <i class="fa-solid fa-trophy"></i>
                        </div>
                        <div>
                            <h2 class="dashboard-kid-title" data-translate="dashboard_title" style="margin: 0; font-family: var(--font-heading); font-weight: 800; font-size: 1.8rem; color: #FAF8F5; text-shadow: 0 2px 4px rgba(0,0,0,0.15);"> Góc Thành Tích Của Em</h2>
                            <p class="dashboard-kid-desc mb-0" data-translate="dashboard_desc" style="font-size: 0.9rem; color: rgba(255, 255, 255, 0.9); font-weight: 500;">Dưới đây là thống kê kết quả và danh sách các thử thách mà em đã vượt qua!</p>
                        </div>
                    </div>

                    <div class="row g-3 flex-grow-1">
                        <!-- Play Count Card -->
                        <div class="col-6">
                            <div class="dashboard-stat-card h-100 text-center p-3 d-flex flex-column justify-content-center align-items-center">
                                <div class="stat-icon-wrapper mb-2" style="background-color: rgba(47, 128, 237, 0.15); color: #2F80ED;">
                                    <i class="fa-solid fa-gamepad" style="font-size: 1.8rem;"></i>
                                </div>
                                <div class="dashboard-stat-value" id="dashboardPlaysCount">0</div>
                                <div class="dashboard-stat-label" data-translate="dashboard_totalplays">Số Lần Chơi</div>
                            </div>
                        </div>

                        <!-- Average Win Rate / Accuracy Card -->
                        <div class="col-6">
                            <div class="dashboard-stat-card h-100 text-center p-3 d-flex flex-column justify-content-center align-items-center">
                                <div class="circular-progress-wrapper mb-2">
                                    <svg width="70" height="70" viewBox="0 0 36 36" class="circular-chart-svg">
                                        <path class="circle-bg"
                                              d="M18 2.0845
                                                 a 15.9155 15.9155 0 0 1 0 31.831
                                                 a 15.9155 15.9155 0 0 1 0 -31.831"
                                              fill="none"
                                              stroke="#EFECE6"
                                              stroke-width="3" />
                                        <path class="circle-progress-bar"
                                              id="dashboardAccuracyCircle"
                                              stroke-dasharray="0, 100"
                                              d="M18 2.0845
                                                 a 15.9155 15.9155 0 0 1 0 31.831
                                                 a 15.9155 15.9155 0 0 1 0 -31.831"
                                              fill="none"
                                              stroke="#27AE60"
                                              stroke-width="3.5"
                                              stroke-linecap="round" />
                                        <text x="18" y="21.5" class="circle-percentage-text" id="dashboardAccuracyText">0%</text>
                                    </svg>
                                </div>
                                <div class="dashboard-stat-label" data-translate="dashboard_winrate">Tỷ Lệ Đúng</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column: Quiz History List -->
                <div class="col-lg-7 col-md-12">
                    <div class="dashboard-history-card p-3 h-100 d-flex flex-column">
                        <h4 class="dashboard-panel-subheading mb-3" data-translate="dashboard_history">Lịch Sử Đề Đã Làm</h4>
                        
                        <!-- History scroll area -->
                        <div class="dashboard-history-scroll flex-grow-1" id="dashboardHistoryListContainer">
                            <!-- Empty State Placeholder -->
                            <div class="dashboard-empty-state text-center py-4" id="dashboardHistoryEmptyState">
                                <div style="font-size: 3rem; margin-bottom: 12px; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));">🏆</div>
                                <p class="px-3" data-translate="dashboard_empty" style="color: var(--text-muted); font-size: 0.9rem; font-weight: 600; line-height: 1.5;">Em chưa tham gia thử thách nào. Hãy chọn một chủ đề phía trên và thử sức ngay nhé! 🚀</p>
                                <button class="btn btn-login-quizkid mt-2 px-4 py-2" data-translate="dashboard_btn_explore" onclick="document.querySelector('.subject-section-kid').scrollIntoView({ behavior: 'smooth', block: 'center' });">🚀 Khám Phá Các Chủ Đề</button>
                            </div>
                            
                            <!-- Dynamic history list -->
                            <div class="dashboard-history-list" id="dashboardHistoryList" style="display: none;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
 
    @* Bảng Vàng đã được ẩn để tránh lạm dụng tên không phù hợp. Chỉ Admin mới xem được qua trang /Admin. *@
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Search JS is removed because search is now handled by redirecting to Library page.
            
            // Achievements Dashboard Logic
            function renderAchievementsDashboard() {
                let history = [];
                try {
                    history = JSON.parse(localStorage.getItem('quizkid_history') || '[]');
                } catch (e) {
                    console.error("Lỗi đọc lịch sử:", e);
                    history = [];
                }

                if (!Array.isArray(history)) {
                    history = [];
                }

                const playsCountEl = document.getElementById('dashboardPlaysCount');
                const accuracyCircleEl = document.getElementById('dashboardAccuracyCircle');
                const accuracyTextEl = document.getElementById('dashboardAccuracyText');
                const emptyStateEl = document.getElementById('dashboardHistoryEmptyState');
                const historyListEl = document.getElementById('dashboardHistoryList');

                if (!playsCountEl || !accuracyCircleEl || !accuracyTextEl || !emptyStateEl || !historyListEl) {
                    return; // Guard if elements are not on the DOM
                }

                const totalPlays = history.length;
                playsCountEl.innerText = totalPlays;

                // Calculate Win Rate (average accuracy or total correct / total questions)
                let avgAccuracy = 0;
                if (totalPlays > 0) {
                    const totalCorrect = history.reduce((sum, item) => sum + (item.correct || 0), 0);
                    const totalQuestions = history.reduce((sum, item) => sum + (item.total || 0), 0);
                    
                    if (totalQuestions > 0) {
                        avgAccuracy = Math.round((totalCorrect / totalQuestions) * 100);
                    } else {
                        const sumAcc = history.reduce((sum, item) => sum + (item.accuracy || 0), 0);
                        avgAccuracy = Math.round(sumAcc / totalPlays);
                    }
                }

                // Animate number and circle progress
                accuracyTextEl.innerText = avgAccuracy + '%';
                // circle stroke dasharray calculation: avgAccuracy (0 to 100)
                accuracyCircleEl.setAttribute('stroke-dasharray', `${avgAccuracy}, 100`);

                if (totalPlays === 0) {
                    emptyStateEl.style.display = 'block';
                    historyListEl.style.display = 'none';
                } else {
                    emptyStateEl.style.display = 'none';
                    historyListEl.style.display = 'flex';
                    
                    let listHtml = '';
                    const lang = localStorage.getItem('selectedLanguage') || 'vi';
                    const scoreLabel = lang === 'vi' ? 'điểm' : 'pts';
                    const correctLabel = lang === 'vi' ? 'Đúng' : 'Correct';
                    const completedOnLabel = lang === 'vi' ? 'Ngày làm: ' : 'Played on: ';

                    history.forEach(item => {
                        const rawTopicName = item.topic || '';
                        let transKey = '';
                        if (rawTopicName.includes('Chủ đề 1')) transKey = 'topic_1';
                        else if (rawTopicName.includes('Chủ đề 2')) transKey = 'topic_2';
                        else if (rawTopicName.includes('Chủ đề 3')) transKey = 'topic_3';
                        else if (rawTopicName.includes('Chủ đề 4')) transKey = 'topic_4';
                        else if (rawTopicName.includes('Tổng hợp')) transKey = 'topic_general';
                        else if (rawTopicName.includes('làng nghề')) transKey = 'topic_craft';
                        else if (rawTopicName.includes('Nghệ nhân')) transKey = 'topic_artisan';
                        else if (rawTopicName.includes('Câu lạc bộ')) transKey = 'topic_club';
                        else if (rawTopicName.includes('Sự kiện') || rawTopicName.includes('Tin tức')) transKey = 'topic_news';
                        
                        let finalTopicName = rawTopicName;
                        if (transKey && window.translations && window.translations[lang] && window.translations[lang][transKey]) {
                            finalTopicName = window.translations[lang][transKey];
                        } else if (!rawTopicName.includes('Chủ đề 5') && !rawTopicName.includes('Chủ đề 6') && 
                                   !rawTopicName.includes('Chủ đề 7') && !rawTopicName.includes('Chủ đề 8') &&
                                   !rawTopicName.includes('Chủ đề 9') && !rawTopicName.includes('Chủ đề 10')) {
                            // Calculate hash similar to C# for fallback topics
                            let hash = 0;
                            for (let i = 0; i < rawTopicName.length; i++) {
                                hash = ((hash << 5) - hash) + rawTopicName.charCodeAt(i);
                                hash |= 0; 
                            }
                            // JS hash matches C# GetHashCode behavior generally, but it might differ slightly.
                            // However, we can just use a simple absolute mod 5 here for visual consistency.
                            hash = Math.abs(hash) % 5;
                            const fallbackNames = ["Khám phá bảo tàng", "Làng nghề thủ công", "Bảng tin cộng đồng", "Góc sáng tạo", "Sự kiện - Tin tức"];
                            finalTopicName = fallbackNames[hash];
                        }
                        
                        let subjectClass = 'art';
                        let iconName = 'fa-palette';

                        if (rawTopicName.includes('Chủ đề 1') || rawTopicName.includes('Tổng hợp')) {
                            subjectClass = 'science';
                            iconName = 'fa-flask';
                        } else if (rawTopicName.includes('Chủ đề 2') || rawTopicName.includes('làng nghề')) {
                            subjectClass = 'math';
                            iconName = 'fa-calculator';
                        } else if (rawTopicName.includes('Chủ đề 3') || rawTopicName.includes('Nghệ nhân')) {
                            subjectClass = 'languages';
                            iconName = 'fa-language';
                        } else {
                            subjectClass = 'art';
                            iconName = 'fa-palette';
                        }

                        listHtml += `
                            <div class="history-item">
                                <div class="history-item-badge ${subjectClass}">
                                    <i class="fa-solid ${iconName}"></i>
                                </div>
                                <div class="history-item-info">
                                    <div class="history-item-topic" title="${finalTopicName}">${finalTopicName}</div>
                                    <div class="history-item-date">${completedOnLabel}${item.date || ''}</div>
                                </div>
                                <div class="history-item-score">
                                    <div class="score-value">${item.score || 0} ${scoreLabel}</div>
                                    <div class="score-accuracy">${correctLabel} ${item.correct || 0}/${item.total || 0} (${Math.round(item.accuracy || 0)}%)</div>
                                </div>
                            </div>
                        `;
                    });

                    historyListEl.innerHTML = listHtml;
                }
            }

            // Render initially
            renderAchievementsDashboard();

            // Listen for language changes to update dynamic strings
            document.addEventListener('langChanged', function () {
                renderAchievementsDashboard();
            });
        });
    </script>
}
