@model List<Bảo_Tàng_Đà_Nẵng.Models.AdminEmail>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Tài khoản Admin";
    var isSuperAdmin = Context.Session.GetString("IsSuperAdmin") == "1";
}

<div class="animate-fadeInUp">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="section-title mb-0" style="text-align:left;">
                <i class="fa-solid fa-shield-halved me-2" style="color:var(--gold-primary);"></i>
                Quản lý Tài khoản Admin
            </h2>
            <p class="section-subtitle mt-1 mb-0" style="text-align:left;">
                Cấp và thu hồi quyền truy cập khu vực quản trị theo địa chỉ Gmail
            </p>
        </div>
        <span style="background:linear-gradient(135deg,#805A12,#8B1E19); color:#FFF8E8; padding:6px 14px; border-radius:20px; font-size:0.78rem; font-weight:600;">
            <i class="fa-solid fa-crown me-1"></i>SUPER ADMIN
        </span>
    </div>

    @if (TempData["SuccessMsg"] != null)
    {
        <div class="alert alert-success mb-4" style="border-radius: 8px;">
            <i class="fa-solid fa-check-circle me-2"></i> @TempData["SuccessMsg"]
        </div>
    }
    @if (TempData["ErrorMsg"] != null)
    {
        <div class="alert alert-danger mb-4" style="border-radius: 8px;">
            <i class="fa-solid fa-exclamation-triangle me-2"></i> @TempData["ErrorMsg"]
        </div>
    }

    <!-- Form cấp quyền Admin mới -->
    <div class="museum-card p-4 mb-4">
        <h5 class="mb-3" style="color:var(--text-dark); font-weight:700;">
            <i class="fa-solid fa-user-plus me-2" style="color:var(--gold-primary);"></i>Cấp quyền Admin mới
        </h5>
        <form asp-action="GrantAdmin" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label font-weight-bold" style="color:var(--text-dark);">Địa chỉ Gmail <span class="text-danger">*</span></label>
                    <input type="email" name="email" class="form-control auth-input bg-white text-dark"
                           placeholder="example@gmail.com" required />
                </div>
                <div class="col-md-5">
                    <label class="form-label font-weight-bold" style="color:var(--text-dark);">Họ và tên <span class="text-danger">*</span></label>
                    <input type="text" name="fullName" class="form-control auth-input bg-white text-dark"
                           placeholder="Nguyễn Văn A" required />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn-primary-museum w-100" style="padding: 12px 16px;">
                        <i class="fa-solid fa-plus me-1"></i>Cấp quyền
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Danh sách email Admin -->
    <div class="museum-card p-0 overflow-hidden">
        <div style="padding: 18px 24px; border-bottom: 1px solid var(--glass-border); background: rgba(10,25,47,0.03);">
            <h5 class="mb-0" style="color:var(--text-dark); font-weight:700;">
                <i class="fa-solid fa-list me-2" style="color:var(--gold-primary);"></i>
                Danh sách Tài khoản Admin (@Model.Count)
            </h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0" style="font-size: 0.95rem;">
                <thead style="background: rgba(10,25,47,0.04);">
                    <tr>
                        <th class="px-4 py-3">Họ và tên</th>
                        <th class="px-4 py-3">Gmail</th>
                        <th class="px-4 py-3">Ngày cấp</th>
                        <th class="px-4 py-3 text-center">Trạng thái</th>
                        <th class="px-4 py-3 text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var admin in Model)
                    {
                        var isSuperAdminRow = string.Equals(admin.Email,
                            Context.RequestServices.GetService<IConfiguration>()!["AppSettings:SuperAdminEmail"],
                            StringComparison.OrdinalIgnoreCase);
                        <tr style="@(admin.IsActive ? "" : "opacity:0.55;")">
                            <td class="px-4 py-3" style="color:var(--text-dark); font-weight:500;">
                                @admin.FullName
                                @if (isSuperAdminRow)
                                {
                                    <span style="font-size:0.72rem; background:linear-gradient(135deg,#FFF2D6,#F5DCA6); color:#805A12; border:1px solid rgba(197,160,89,0.5); border-radius:10px; padding:2px 8px; margin-left:6px; font-weight:600;">
                                        <i class="fa-solid fa-crown me-1"></i>Super Admin
                                    </span>
                                }
                            </td>
                            <td class="px-4 py-3" style="color:var(--text-dark);">
                                <i class="fa-brands fa-google me-1" style="color:#EA4335;"></i>
                                @admin.Email
                            </td>
                            <td class="px-4 py-3" style="color:var(--text-muted); font-size:0.88rem;">
                                @admin.AddedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td class="px-4 py-3 text-center">
                                @if (admin.IsActive)
                                {
                                    <span style="background:rgba(16,185,129,0.15); color:#059669; border-radius:20px; padding:4px 12px; font-size:0.8rem; font-weight:600;">
                                        <i class="fa-solid fa-circle me-1" style="font-size:0.5rem; vertical-align:middle;"></i>Đang hoạt động
                                    </span>
                                }
                                else
                                {
                                    <span style="background:rgba(107,114,128,0.12); color:#6b7280; border-radius:20px; padding:4px 12px; font-size:0.8rem; font-weight:600;">
                                        <i class="fa-solid fa-ban me-1"></i>Đã thu hồi
                                    </span>
                                }
                            </td>
                            <td class="px-4 py-3 text-center">
                                @if (!isSuperAdminRow && admin.IsActive)
                                {
                                    <form asp-action="RevokeAdmin" asp-route-id="@admin.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                style="font-size:0.8rem; padding:4px 10px;"
                                                onclick="return confirm('Thu hồi quyền Admin của @admin.Email?');">
                                            <i class="fa-solid fa-user-slash me-1"></i>Thu hồi
                                        </button>
                                    </form>
                                }
                                else if (!isSuperAdminRow && !admin.IsActive)
                                {
                                    <form asp-action="GrantAdmin" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="email" value="@admin.Email" />
                                        <input type="hidden" name="fullName" value="@admin.FullName" />
                                        <button type="submit" class="btn btn-sm btn-outline-success"
                                                style="font-size:0.8rem; padding:4px 10px;">
                                            <i class="fa-solid fa-user-check me-1"></i>Khôi phục
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span style="color:var(--text-muted); font-size:0.8rem;">—</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5" style="color:var(--text-muted);">
                                <i class="fa-solid fa-users-slash" style="font-size:2rem; opacity:0.3; display:block; margin-bottom:8px;"></i>
                                Chưa có tài khoản Admin nào được cấp quyền.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
