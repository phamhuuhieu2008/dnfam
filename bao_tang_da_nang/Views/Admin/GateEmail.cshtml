@{
    ViewData["Title"] = "Xác thực quản trị - Bước 2";
    ViewData["HideNav"] = true;
}

<div class="auth-page animate-fadeInUp">
    <div class="auth-logo">
        <div class="logo-icon">📧</div>
        <h1>Xác thực Gmail</h1>
        <p>Nhập Gmail được cấp quyền để nhận mã OTP</p>
    </div>

    <!-- Progress Steps -->
    <div style="display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 28px;">
        <div style="display:flex; align-items:center; gap: 6px;">
            <div style="width:28px; height:28px; border-radius:50%; background:var(--success); display:flex; align-items:center; justify-content:center; color:#fff; font-size:0.8rem; font-weight:700;">✓</div>
            <span style="font-size:0.8rem; color: var(--success); font-weight:600;">PIN</span>
        </div>
        <div style="width:36px; height:2px; background: var(--gold-primary); opacity:0.4;"></div>
        <div style="display:flex; align-items:center; gap: 6px;">
            <div style="width:28px; height:28px; border-radius:50%; background:var(--gold-primary); display:flex; align-items:center; justify-content:center; color:#fff; font-size:0.8rem; font-weight:700;">2</div>
            <span style="font-size:0.8rem; color: var(--gold-primary); font-weight:600;">Gmail</span>
        </div>
        <div style="width:36px; height:2px; background: var(--glass-border);"></div>
        <div style="display:flex; align-items:center; gap: 6px;">
            <div style="width:28px; height:28px; border-radius:50%; border:2px solid var(--glass-border); display:flex; align-items:center; justify-content:center; color:var(--text-muted); font-size:0.8rem; font-weight:700;">3</div>
            <span style="font-size:0.8rem; color: var(--text-muted); font-weight:500;">OTP</span>
        </div>
    </div>

    <div class="auth-card">
        <div class="auth-card-header">
            <h2>Nhập địa chỉ Gmail</h2>
            <p>Chỉ Gmail đã được Super Admin cấp quyền mới nhận được mã OTP</p>
        </div>

        <div class="auth-card-body">
            @if (TempData["ErrorMsg"] != null)
            {
                <div class="alert-museum error">
                    <span>⚠️</span>
                    <span>@TempData["ErrorMsg"]</span>
                </div>
            }

            @if (TempData["SuccessMsg"] != null)
            {
                <div class="alert-museum success">
                    <span>✅</span>
                    <span>@TempData["SuccessMsg"]</span>
                </div>
            }

            <form asp-controller="Admin" asp-action="GateEmail" method="post" id="emailForm">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label for="email" class="form-label">Địa chỉ Gmail</label>
                    <input type="email"
                           name="email"
                           id="email"
                           class="form-input"
                           placeholder="example@gmail.com"
                           autocomplete="email"
                           autofocus
                           required />
                </div>

                <div class="mt-24">
                    <button type="submit" id="btnSendOtp" class="btn-primary-museum">
                        <i class="fa-solid fa-paper-plane me-2"></i>Gửi mã OTP
                    </button>
                </div>
            </form>

            <div class="auth-footer-link mt-16">
                <a asp-controller="Admin" asp-action="Gate">← Quay lại bước 1</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function() {
    const form = document.getElementById('emailForm');
    const btn = document.getElementById('btnSendOtp');

    if (form && btn) {
        form.addEventListener('submit', function() {
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner"></span>&nbsp; Đang gửi OTP...';
        });
    }
})();
</script>
}
