@model List<Bảo_Tàng_Đà_Nẵng.Models.Question>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Câu hỏi";
    
    // Get unique categories for the filter
    var categories = Model.Select(q => q.LocationName).Where(l => !string.IsNullOrEmpty(l)).Distinct().ToList();
    var currentFilter = Context.Request.Query["category"].ToString();
}

<div class="animate-fadeInUp">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="section-title text-dark mb-0" style="text-align: left;">Ngân hàng Câu hỏi</h2>
            <p class="section-subtitle mt-1 mb-0" style="text-align: left;">Quản lý toàn bộ câu hỏi trong hệ thống</p>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <form asp-action="ImportJsonData" method="post" class="m-0" onsubmit="return confirm('Hành động này sẽ xoá dữ liệu cũ và nạp lại toàn bộ câu hỏi từ file quiz_data.json. Bạn có chắc chắn?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-primary-museum px-3 py-2 text-decoration-none" style="width: auto; background: var(--secondary);"><i class="fa-solid fa-rotate me-1"></i> Đồng bộ JSON</button>
            </form>
            <a asp-action="CreateQuestion" class="btn-primary-museum px-3 py-2 text-decoration-none" style="width: auto;"><i class="fa-solid fa-plus me-1"></i> Thêm Mới</a>
        </div>
    </div>

    @if (TempData["SuccessMsg"] != null)
    {
        <div class="alert alert-success mb-4" style="border-radius: 8px;">
            <i class="fa-solid fa-check-circle me-2"></i> @TempData["SuccessMsg"]
        </div>
    }
    @if (TempData["ErrorMsg"] != null)
    {
        <div class="alert alert-danger mb-4" style="border-radius: 8px;">
            <i class="fa-solid fa-exclamation-triangle me-2"></i> @TempData["ErrorMsg"]
        </div>
    }

    <!-- Lọc danh mục & Tìm kiếm -->
    <div class="museum-card p-3 mb-4 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
        <div class="d-flex align-items-center gap-2 mb-2 mb-md-0">
            <i class="fa-solid fa-filter text-muted"></i>
            <span class="font-weight-bold" style="color: var(--text-dark);">Bộ lọc & Tìm kiếm:</span>
        </div>
        <form method="get" class="d-flex flex-column flex-md-row gap-2 m-0 flex-grow-1 justify-content-end">
            <div class="input-group" style="max-width: 300px;">
                <input type="text" name="search" class="form-control bg-white text-dark" placeholder="Tìm nội dung câu hỏi..." value="@ViewData["SearchString"]" style="border: 1px solid var(--glass-border); border-radius: 8px 0 0 8px;">
                <button type="submit" class="btn btn-primary" style="background: var(--gold-primary); border: none; border-radius: 0 8px 8px 0;">
                    <i class="fa-solid fa-search"></i>
                </button>
            </div>
            <select name="category" class="form-select bg-white text-dark" style="border: 1px solid var(--glass-border); border-radius: 8px; max-width: 250px;" onchange="this.form.submit()">
                <option value="">-- Tất cả danh mục --</option>
                @foreach(var cat in categories)
                {
                    if (currentFilter == cat)
                    {
                        <option value="@cat" selected>@cat</option>
                    }
                    else
                    {
                        <option value="@cat">@cat</option>
                    }
                }
            </select>
        </form>
    </div>

    <div class="museum-card p-0 overflow-hidden">
        <div class="table-responsive" style="border: none;">
            <table class="table table-hover mb-0" style="font-size: 0.9rem;">
                <thead style="background: rgba(10, 25, 47, 0.04);">
                    <tr>
                        <th class="px-4 py-3" style="width: 5%;">ID</th>
                        <th class="px-4 py-3" style="width: 35%;">Nội dung</th>
                        <th class="px-4 py-3 text-center">Đáp án</th>
                        <th class="px-4 py-3 text-center">Điểm</th>
                        <th class="px-4 py-3">Danh mục</th>
                        <th class="px-4 py-3 text-center">Trạng thái</th>
                        <th class="px-4 py-3 text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var filteredModel = string.IsNullOrEmpty(currentFilter) 
                                            ? Model 
                                            : Model.Where(q => q.LocationName == currentFilter).ToList();
                    }
                    @foreach(var q in filteredModel)
                    {
                        <tr>
                            <td class="px-4 py-3 text-muted">#@q.Id</td>
                            <td class="px-4 py-3" style="color: var(--text-dark); font-weight: 500;">@q.Content</td>
                            <td class="px-4 py-3 text-center">
                                <span class="rank-badge gold d-inline-flex" style="width: 24px; height: 24px; font-size: 0.8rem;">@q.CorrectOption</span>
                            </td>
                            <td class="px-4 py-3 text-center" style="color: var(--primary);">@q.Points</td>
                            <td class="px-4 py-3 text-muted">@q.LocationName</td>
                            <td class="px-4 py-3 text-center">
                                @if(q.IsActive) { <span class="badge" style="background: var(--success); color: white; padding: 4px 8px; border-radius: 4px;">Hiện</span> }
                                else { <span class="badge" style="background: var(--error); color: white; padding: 4px 8px; border-radius: 4px;">Ẩn</span> }
                            </td>
                            <td class="px-4 py-3 text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="EditQuestion" asp-route-id="@q.Id" class="btn btn-sm btn-outline-primary" style="font-size: 0.8rem; padding: 4px 8px;" title="Sửa">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    <form asp-action="ToggleQuestionStatus" asp-route-id="@q.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(q.IsActive ? "btn-outline-danger" : "btn-outline-success")" style="font-size: 0.8rem; padding: 4px 8px;" title="@(q.IsActive ? "Ẩn" : "Hiện")" onclick="return confirm('Bạn có chắc muốn @(q.IsActive ? "ẩn" : "hiện") câu hỏi này?');">
                                            @if (q.IsActive)
                                            {
                                                <i class="fa-solid fa-eye-slash"></i>
                                            }
                                            else
                                            {
                                                <i class="fa-solid fa-eye"></i>
                                            }
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (filteredModel.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">Không tìm thấy câu hỏi nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
