@model List<Bảo_Tàng_Đà_Nẵng.Models.User>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Người dùng";
}

<div class="animate-fadeInUp">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="section-title text-dark mb-0" style="text-align: left;">Danh sách Người dùng</h2>
            <p class="section-subtitle mt-1 mb-0" style="text-align: left;">Quản lý tài khoản người chơi & Quản trị viên</p>
        </div>
    </div>

    @if (TempData["SuccessMsg"] != null)
    {
        <div class="alert alert-success mb-4" style="border-radius: 8px;">
            <i class="fa-solid fa-check-circle me-2"></i> @TempData["SuccessMsg"]
        </div>
    }
    @if (TempData["ErrorMsg"] != null)
    {
        <div class="alert alert-danger mb-4" style="border-radius: 8px;">
            <i class="fa-solid fa-exclamation-triangle me-2"></i> @TempData["ErrorMsg"]
        </div>
    }

    <!-- Tìm kiếm -->
    <div class="museum-card p-3 mb-4 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
        <div class="d-flex align-items-center gap-2 mb-2 mb-md-0">
            <i class="fa-solid fa-search text-muted"></i>
            <span class="font-weight-bold" style="color: var(--text-dark);">Tìm kiếm:</span>
        </div>
        <form method="get" class="d-flex gap-2 m-0 flex-grow-1 justify-content-end">
            <div class="input-group" style="max-width: 400px;">
                <input type="text" name="search" class="form-control bg-white text-dark" placeholder="Tên đăng nhập hoặc họ tên..." value="@ViewData["SearchString"]" style="border: 1px solid var(--glass-border); border-radius: 8px 0 0 8px;">
                <button type="submit" class="btn btn-primary" style="background: var(--gold-primary); border: none; border-radius: 0 8px 8px 0;">
                    <i class="fa-solid fa-search"></i> Tìm
                </button>
            </div>
        </form>
    </div>

    <div class="museum-card p-0 overflow-hidden">
        <div class="table-responsive" style="border: none;">
            <table class="table table-hover mb-0" style="font-size: 0.95rem;">
                <thead style="background: rgba(10, 25, 47, 0.04);">
                    <tr>
                        <th class="px-4 py-3">Tên người dùng</th>
                        <th class="px-4 py-3">Số điểm</th>
                        <th class="px-4 py-3 text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var u in Model)
                    {
                        <tr>
                            <td class="px-4 py-3" style="color: var(--text-dark); font-weight: 500;">
                                @u.FullName
                                @if(u.Role == "Admin") { <span style="font-size: 0.75rem; color: var(--primary); margin-left: 5px;"><i class="fa-solid fa-crown text-warning"></i> Admin</span> }
                            </td>
                            <td class="px-4 py-3" style="color: var(--gold-primary); font-weight: bold;">
                                @(u.QuizSessions?.Sum(s => s.TotalScore) ?? 0)
                            </td>
                            <td class="px-4 py-3 text-center">
                                @if (u.Role != "Admin")
                                {
                                    <form asp-action="DeleteUser" asp-route-id="@u.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" style="font-size: 0.8rem; padding: 4px 8px;" onclick="return confirm('Bạn có chắc muốn xóa người dùng này?');" title="Xóa">
                                            <i class="fa-solid fa-trash-can"></i> Xóa
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">Không tìm thấy người dùng nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>