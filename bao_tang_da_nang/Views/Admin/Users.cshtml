@model List<Bảo_Tàng_Đà_Nẵng.Models.User>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Người dùng";
}

<div class="animate-fadeInUp">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="section-title text-dark mb-0" style="text-align: left;">Danh sách Người dùng</h2>
            <p class="section-subtitle mt-1 mb-0" style="text-align: left;">Quản lý tài khoản người chơi & Quản trị viên</p>
        </div>
    </div>

    @if (TempData["SuccessMsg"] != null)
    {
        <div class="alert alert-success mb-4" style="border-radius: 8px;">
            <i class="fa-solid fa-check-circle me-2"></i> @TempData["SuccessMsg"]
        </div>
    }
    @if (TempData["ErrorMsg"] != null)
    {
        <div class="alert alert-danger mb-4" style="border-radius: 8px;">
            <i class="fa-solid fa-exclamation-triangle me-2"></i> @TempData["ErrorMsg"]
        </div>
    }

    <!-- Tìm kiếm -->
    <div class="museum-card p-3 mb-4 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
        <div class="d-flex align-items-center gap-2 mb-2 mb-md-0">
            <i class="fa-solid fa-search text-muted"></i>
            <span class="font-weight-bold" style="color: var(--text-dark);">Tìm kiếm:</span>
        </div>
        <form method="get" class="d-flex gap-2 m-0 flex-grow-1 justify-content-end">
            <div class="input-group" style="max-width: 400px;">
                <input type="text" name="search" class="form-control bg-white text-dark" placeholder="Tên đăng nhập hoặc họ tên..." value="@ViewData["SearchString"]" style="border: 1px solid var(--glass-border); border-radius: 8px 0 0 8px;">
                <button type="submit" class="btn btn-primary" style="background: var(--gold-primary); border: none; border-radius: 0 8px 8px 0;">
                    <i class="fa-solid fa-search"></i> Tìm
                </button>
            </div>
        </form>
    </div>

    <div class="museum-card p-0 overflow-hidden">
        <div class="table-responsive" style="border: none;">
            <table class="table table-hover mb-0" style="font-size: 0.95rem;">
                <thead style="background: rgba(10, 25, 47, 0.04);">
                    <tr>
                        <th class="px-4 py-3" style="width: 5%;">ID</th>
                        <th class="px-4 py-3">Tên đăng nhập</th>
                        <th class="px-4 py-3">Họ và Tên</th>
                        <th class="px-4 py-3">Vai trò</th>
                        <th class="px-4 py-3">Ngày đăng ký</th>
                        <th class="px-4 py-3 text-center">Trạng thái</th>
                        <th class="px-4 py-3 text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var u in Model)
                    {
                        <tr>
                            <td class="px-4 py-3 text-muted">#@u.Id</td>
                            <td class="px-4 py-3" style="color: var(--text-dark); font-weight: 500;">@u.Username</td>
                            <td class="px-4 py-3" style="color: var(--text-dark);">@u.FullName</td>
                            <td class="px-4 py-3">
                                @if(u.Role == "Admin") { <span style="color: var(--primary); font-weight: bold;"><i class="fa-solid fa-crown text-warning me-1"></i> Admin</span> }
                                else { <span class="text-muted">Player</span> }
                            </td>
                            <td class="px-4 py-3 text-muted">@u.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td class="px-4 py-3 text-center">
                                @if(u.IsActive) { <span class="badge" style="background: var(--success); color: white; padding: 4px 8px; border-radius: 4px;">Hoạt động</span> }
                                else { <span class="badge" style="background: var(--error); color: white; padding: 4px 8px; border-radius: 4px;">Bị khóa</span> }
                            </td>
                            <td class="px-4 py-3 text-center">
                                @if (u.Role != "Admin")
                                {
                                    <form asp-action="ToggleUserStatus" asp-route-id="@u.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(u.IsActive ? "btn-outline-danger" : "btn-outline-success")" style="font-size: 0.8rem; padding: 4px 8px;" onclick="return confirm('Bạn có chắc muốn @(u.IsActive ? "khóa" : "mở khóa") tài khoản này?');" title="@(u.IsActive ? "Khóa" : "Mở Khóa")">
                                            @if (u.IsActive)
                                            {
                                                <i class="fa-solid fa-lock"></i>
                                            }
                                            else
                                            {
                                                <i class="fa-solid fa-unlock"></i>
                                            }
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">Không tìm thấy người dùng nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>