@model Bảo_Tàng_Đà_Nẵng.Models.Question
@{
    Layout = "_AdminLayout";
    bool isCreate = Model.Id == 0;
    ViewData["Title"] = isCreate ? "Thêm mới Câu hỏi" : "Chỉnh sửa Câu hỏi";
}

<div class="animate-fadeInUp" style="max-width: 800px; margin: 0 auto;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="section-title mb-0" style="text-align: left;">@(isCreate ? "Thêm Mới Câu Hỏi" : "Chỉnh Sửa Câu Hỏi")</h2>
            <p class="section-subtitle mt-1" style="text-align: left;">@if(!isCreate) { <span>Câu hỏi ID: #@Model.Id</span> }</p>
        </div>
        <a asp-action="Questions" class="btn-secondary-museum px-4 py-2 text-decoration-none" style="width: auto;"><i class="fa-solid fa-arrow-left me-1"></i> Trở về</a>
    </div>

    <div class="museum-card p-4">
        <form asp-action="@(isCreate ? "CreateQuestion" : "EditQuestion")" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            @if (!isCreate)
            {
                <input type="hidden" asp-for="Id" />
            }

            <div class="mb-4">
                <label asp-for="Content" class="form-label font-weight-bold" style="color: var(--text-dark) !important;">Nội dung Câu hỏi <span class="text-danger">*</span></label>
                <textarea asp-for="Content" class="form-control auth-input bg-white text-dark" rows="3" required placeholder="Nhập nội dung câu hỏi..."></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <label asp-for="OptionA" class="form-label font-weight-bold" style="color: var(--text-dark) !important;">Đáp án A <span class="text-danger">*</span></label>
                    <input asp-for="OptionA" class="form-control auth-input bg-white text-dark" required />
                    <span asp-validation-for="OptionA" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="OptionB" class="form-label font-weight-bold" style="color: var(--text-dark) !important;">Đáp án B <span class="text-danger">*</span></label>
                    <input asp-for="OptionB" class="form-control auth-input bg-white text-dark" required />
                    <span asp-validation-for="OptionB" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="OptionC" class="form-label font-weight-bold" style="color: var(--text-dark) !important;">Đáp án C <span class="text-danger">*</span></label>
                    <input asp-for="OptionC" class="form-control auth-input bg-white text-dark" required />
                    <span asp-validation-for="OptionC" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="OptionD" class="form-label font-weight-bold" style="color: var(--text-dark) !important;">Đáp án D <span class="text-danger">*</span></label>
                    <input asp-for="OptionD" class="form-control auth-input bg-white text-dark" required />
                    <span asp-validation-for="OptionD" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-4">
                    <label asp-for="CorrectOption" class="form-label font-weight-bold" style="color: var(--text-dark) !important;">Đáp án Đúng <span class="text-danger">*</span></label>
                    <select asp-for="CorrectOption" class="form-select auth-input bg-white text-dark" required style="height: 52px; border: 1px solid var(--glass-border);">
                        <option value="A">A</option>
                        <option value="B">B</option>
                        <option value="C">C</option>
                        <option value="D">D</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="Points" class="form-label font-weight-bold" style="color: var(--text-dark) !important;">Điểm thưởng <span class="text-danger">*</span></label>
                    <input asp-for="Points" class="form-control auth-input bg-white text-dark" type="number" min="1" value="@(isCreate ? 10 : Model.Points)" required />
                </div>
                <div class="col-md-4">
                    <label asp-for="LocationName" class="form-label font-weight-bold" style="color: var(--text-dark) !important;">Danh mục/Chủ đề (Tuỳ chọn)</label>
                    <input asp-for="LocationName" class="form-control auth-input bg-white text-dark" placeholder="VD: Bảo Tàng Đà Nẵng" />
                </div>
            </div>

            <div class="mb-5">
                <label class="form-label font-weight-bold" style="color: var(--text-dark) !important;">Hình ảnh minh hoạ (Tuỳ chọn)</label>
                <input type="file" name="imageFile" class="form-control auth-input bg-white text-dark" accept="image/*" />
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mt-2 d-flex align-items-center gap-3">
                        <small class="text-muted">Hình ảnh hiện tại: <a href="@Model.ImageUrl" target="_blank">Xem hình</a></small>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="RemoveImage" value="true" id="RemoveImage">
                            <label class="form-check-label text-danger" style="font-size: 0.85rem;" for="RemoveImage">
                                <i class="fa-solid fa-trash-can"></i> Xóa ảnh này
                            </label>
                        </div>
                    </div>
                }
            </div>

            <button type="submit" class="btn-primary-museum w-100">
                <i class="fa-solid fa-save me-2"></i> @(isCreate ? "LƯU CÂU HỎI MỚI" : "CẬP NHẬT CÂU HỎI")
            </button>
        </form>
    </div>
</div>