@model QuizResultViewModel
@{
    ViewData["Title"] = "Kết quả Giải Mã";
}

<div class="kid-quiz-page animate-fadeInUp">
    <div class="kid-result-card">
        <div class="kid-result-header">
            <h2 class="section-title text-dark mb-0" data-translate="finish_header">🎉 Hoàn thành xuất sắc!</h2>
            <p class="section-subtitle mt-8" data-translate="finish_subtitle">Em đã hoàn thành chuyến phiêu lưu rồi!</p>
        </div>

        <div class="kid-score-bubble">
            <div class="score-number">@Model.TotalScore</div>
            <div class="score-unit" data-translate="finish_score_unit">ĐIỂM</div>
        </div>

        <div class="px-3">
            <div class="text-center mb-3" style="font-weight: 800; color: #8B1E19; font-size: 1.05rem;">
                @Model.PlayerName
            </div>

            <div class="kid-kpi-row">
                <div class="kid-kpi">
                    <div class="kpi-value">@Model.CorrectAnswers</div>
                    <div class="kpi-label" data-translate="finish_kpi_correct">Câu đúng</div>
                </div>
                <div class="kid-kpi">
                    <div class="kpi-value">@Model.AccuracyRate%</div>
                    <div class="kpi-label" data-translate="finish_kpi_accuracy">Chính xác</div>
                </div>
                <div class="kid-kpi">
                    <div class="kpi-value">@Model.TotalQuestions</div>
                    <div class="kpi-label" data-translate="finish_kpi_total">Tổng câu</div>
                </div>
                <div class="kid-kpi">
                    <div class="kpi-value">@Model.Duration.Minutes:@Model.Duration.Seconds.ToString("D2")</div>
                    <div class="kpi-label" data-translate="finish_kpi_time">Thời gian</div>
                </div>
            </div>
        </div>

        <div class="divider" data-translate="finish_divider">Chi tiết bài làm</div>

        <div class="pb-3">
            @for (int i = 0; i < Model.Answers.Count; i++)
            {
                var ans = Model.Answers[i];
                <div class="kid-review-item">
                    <div class="review-question">
                        <span data-translate="finish_review_q">Câu</span> @(i + 1): @ans.QuestionContent
                    </div>

                    <div class="review-meta">
                        <div>
                            @if (ans.IsCorrect)
                            {
                                <span style="color: var(--success); font-weight: 800;" data-translate="finish_review_correct">✅ Đúng rồi!</span>
                            }
                            else
                            {
                                <span style="color: var(--error); font-weight: 800;" data-translate="finish_review_wrong">❌ Chưa đúng</span>
                                <span style="color: var(--text-muted); font-weight: 700;"><span data-translate="finish_review_answer_label"> (Đáp án: </span>@ans.CorrectOption)</span>
                            }
                        </div>
                        <div class="score">
                            +@(ans.IsCorrect ? ans.Points : 0) <span data-translate="finish_review_points">điểm</span>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="p-3">
            <a asp-controller="Home" asp-action="Index" class="btn-primary-museum text-center" style="display: block; text-decoration: none; margin-bottom: 12px;" data-translate="finish_home_btn">
                🏠 Về trang chủ
            </a>

            <a asp-controller="Quiz" asp-action="StartSession" class="btn-secondary-museum text-center" style="display: block; text-decoration: none;" data-translate="finish_replay_btn">
                🔁 Chơi lại lần nữa
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Retrieve session stats from ViewBag and Model
            const topic = "@Html.Raw(ViewBag.TopicName ?? "Trắc nghiệm Tổng hợp")";
            const score = @Model.TotalScore;
            const correct = @Model.CorrectAnswers;
            const total = @Model.TotalQuestions;
            const accuracy = @Model.AccuracyRate;
            const sessionId = @Model.SessionId;
            const date = new Date().toLocaleDateString('vi-VN', {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit',
                hour: '2-digit',
                minute: '2-digit'
            });

            // Get existing history array
            let history = [];
            try {
                history = JSON.parse(localStorage.getItem('quizkid_history') || '[]');
            } catch (e) {
                console.error("Lỗi đọc lịch sử:", e);
                history = [];
            }

            if (!Array.isArray(history)) {
                history = [];
            }

            // Check if this sessionId already exists to prevent duplicate addition on page reload
            const exists = history.some(item => item.sessionId === sessionId);

            if (!exists) {
                // Add new record to the beginning of the list
                history.unshift({
                    sessionId: sessionId,
                    topic: topic,
                    score: score,
                    correct: correct,
                    total: total,
                    accuracy: accuracy,
                    date: date
                });

                // Keep only the last 50 entries to save space
                if (history.length > 50) {
                    history = history.slice(0, 50);
                }

                // Save back to localStorage
                localStorage.setItem('quizkid_history', JSON.stringify(history));
            }
        });
    </script>
}

