@model QuestionViewModel
@{
    ViewData["Title"] = $"Câu {Model.CurrentIndex}/{Model.TotalQuestions}";
    ViewData["HideNav"] = true;
    ViewData["HideFooter"] = true;
    double progressPercent = ((double)Model.CurrentIndex / Model.TotalQuestions) * 100;
}

@section Styles {
<style>
    /* ─── Ẩn footer & navbar links khi đang làm bài ─── */
    .footer-quizkid { display: none !important; }
    .navbar-quizkid { display: none !important; }

    /* ─── Layout tổng thể ─── */
    .kid-quiz-page {
        max-width: 800px;
        margin: 0 auto;
        padding: 16px 16px 110px 16px; /* bottom padding cho nút cố định */
    }

    /* ─── Toast feedback ─── */
    .feedback-toast {
        position: fixed;
        top: 70px;
        left: 50%;
        transform: translateX(-50%) translateY(-10px);
        z-index: 9999;
        padding: 12px 24px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 1rem;
        box-shadow: 0 8px 24px rgba(0,0,0,0.18);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease, transform 0.3s ease;
        white-space: nowrap;
        max-width: 90vw;
    }
    .feedback-toast.show {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
    }
    .feedback-toast.hide {
        opacity: 0;
        transform: translateX(-50%) translateY(-10px);
    }
    .feedback-toast.correct {
        background: linear-gradient(135deg, #28a745, #20c997);
        color: white;
    }
    .feedback-toast.wrong {
        background: linear-gradient(135deg, #dc3545, #ff6b6b);
        color: white;
    }

    /* ─── Nút Tiếp tục cố định dưới cùng ─── */
    .bottom-action {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        transform: none !important; /* Ghi đè transform: translateX(-50%) từ museum.css */
        width: 100% !important;
        z-index: 1000;
        padding: 12px 16px 16px 16px;
        background: linear-gradient(to top, rgba(255,255,255,1) 60%, rgba(255,255,255,0));
        display: none;
    }
    .bottom-action .btn-primary-museum {
        width: 100%;
        max-width: 800px;
        margin: 0 auto;
        display: block;
        padding: 16px;
        border-radius: 50px;
        font-size: 1.1rem;
        font-weight: 800;
        text-align: center;
        background: linear-gradient(180deg, #F9B621 0%, #E89100 100%);
        color: white;
        border: none;
        box-shadow: 0 8px 20px rgba(232, 145, 0, 0.35), inset 0 -3px 0 rgba(0,0,0,0.1);
        cursor: pointer;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .bottom-action .btn-primary-museum:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 24px rgba(232, 145, 0, 0.4);
    }
    .bottom-action .btn-primary-museum:active {
        transform: translateY(0);
    }
    .bottom-action .btn-primary-museum:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    /* ─── Mobile responsive ─── */
    @@media (max-width: 768px) {
        .kid-quiz-page {
            padding: 10px 10px 110px 10px;
        }
        .kid-question-card {
            padding: 18px 14px !important;
            margin-bottom: 12px !important;
            border-radius: 20px !important;
        }
        .question-content {
            font-size: 1.1rem !important;
            line-height: 1.5 !important;
        }
        .kid-answers-grid {
            grid-template-columns: 1fr !important;
            gap: 10px !important;
        }
        .kid-answer-option {
            padding: 14px 16px !important;
            min-height: 56px !important;
            border-radius: 16px !important;
        }
        .answer-text {
            font-size: 0.98rem !important;
        }
        .answer-letter {
            width: 38px !important;
            height: 38px !important;
            font-size: 1rem !important;
            border-radius: 11px !important;
            flex-shrink: 0;
        }
        .feedback-toast {
            font-size: 0.9rem;
            padding: 10px 18px;
        }
        .bottom-action .btn-primary-museum {
            padding: 15px;
            font-size: 1.05rem;
        }
    }
</style>
}

<div id="feedbackToast" class="feedback-toast"></div>

<div class="kid-quiz-page animate-fadeInUp">
    <div class="kid-quiz-progress">
        <div class="quiz-progress-info">
            <div class="q-counter"><span data-translate="finish_review_q">Câu</span> @Model.CurrentIndex / @Model.TotalQuestions</div>
            <div class="q-score" id="scoreDisplay">@Model.CurrentScore <span data-translate="finish_review_points">điểm</span></div>
        </div>
        <div class="progress-bar-track">
            <div class="progress-bar-fill" style="width: @progressPercent%"></div>
        </div>
    </div>

    <div class="kid-question-card">
        @if (!string.IsNullOrEmpty(Model.LocationName))
        {
            <div class="location-badge">📍 @Model.LocationName</div>
        }

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="Hình ảnh câu hỏi" class="question-image" />
        }

        <div class="question-content">
            <span class="lang-text lang-vi">@Model.Content</span>
            <span class="lang-text lang-en" style="display:none;">@(string.IsNullOrEmpty(Model.ContentEn) ? Model.Content : Model.ContentEn)</span>
        </div>

        <div class="question-points">
            <span data-translate="question_points_prefix">⭐ Mỗi câu đúng được</span> @Model.Points <span data-translate="question_points_suffix">điểm</span>
        </div>
    </div>

    <div class="kid-answers-grid" id="answersGrid">
        <div class="answer-option kid-answer-option" data-option="A">
            <div class="answer-letter">A</div>
            <div class="answer-text">
                <span class="lang-text lang-vi">@Model.OptionA</span>
                <span class="lang-text lang-en" style="display:none;">@(string.IsNullOrEmpty(Model.OptionAEn) ? Model.OptionA : Model.OptionAEn)</span>
            </div>
        </div>

        <div class="answer-option kid-answer-option" data-option="B">
            <div class="answer-letter">B</div>
            <div class="answer-text">
                <span class="lang-text lang-vi">@Model.OptionB</span>
                <span class="lang-text lang-en" style="display:none;">@(string.IsNullOrEmpty(Model.OptionBEn) ? Model.OptionB : Model.OptionBEn)</span>
            </div>
        </div>

        <div class="answer-option kid-answer-option" data-option="C">
            <div class="answer-letter">C</div>
            <div class="answer-text">
                <span class="lang-text lang-vi">@Model.OptionC</span>
                <span class="lang-text lang-en" style="display:none;">@(string.IsNullOrEmpty(Model.OptionCEn) ? Model.OptionC : Model.OptionCEn)</span>
            </div>
        </div>

        <div class="answer-option kid-answer-option" data-option="D">
            <div class="answer-letter">D</div>
            <div class="answer-text">
                <span class="lang-text lang-vi">@Model.OptionD</span>
                <span class="lang-text lang-en" style="display:none;">@(string.IsNullOrEmpty(Model.OptionDEn) ? Model.OptionD : Model.OptionDEn)</span>
            </div>
        </div>
    </div>
</div>

<!-- Nút Tiếp tục cố định ở dưới màn hình -->
<div class="bottom-action" id="bottomActionContainer">
    <button type="button" class="btn-primary-museum" id="btnNext" data-translate="question_next_btn">
        Tiếp tục <span style="font-size: 1.2em; vertical-align: middle;">→</span>
    </button>
</div>

<form id="antiForgeryForm">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function() {
    const optionsGrid = document.getElementById('answersGrid');
    const options = document.querySelectorAll('.answer-option');
    const btnNext = document.getElementById('btnNext');
    const bottomAction = document.getElementById('bottomActionContainer');
    const toast = document.getElementById('feedbackToast');
    const scoreDisplay = document.getElementById('scoreDisplay');
    const afToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

    let isAnswered = false;
    let nextUrl = '@Url.Action("Question", "Quiz")';
    let toastTimer = null;

    // Dynamic localization states
    let currentLang = localStorage.getItem('selectedLanguage') || 'vi';
    let isLast = false;
    let lastPoints = @Model.CurrentScore;

    document.addEventListener('langChanged', function(e) {
        currentLang = e.detail.lang;
        updateDynamicElements();
    });

    function updateDynamicElements() {
        const scoreSuffix = currentLang === 'vi' ? ' điểm' : ' pts';
        scoreDisplay.innerHTML = lastPoints + ` <span data-translate="finish_review_points">${scoreSuffix}</span>`;
        
        if (isLast) {
            btnNext.innerHTML = currentLang === 'vi' 
                ? 'Xem kết quả <span style="font-size: 1.2em; vertical-align: middle;">🏆</span>' 
                : 'View Results <span style="font-size: 1.2em; vertical-align: middle;">🏆</span>';
            btnNext.setAttribute('data-is-last', 'true');
        }

        document.querySelectorAll('.lang-text').forEach(el => {
            el.style.display = 'none';
        });
        document.querySelectorAll('.lang-' + currentLang).forEach(el => {
            el.style.display = 'inline';
        });
    }

    // Toast với auto-hide sau 3.5 giây
    function showToast(message, type) {
        // Clear timer cũ nếu có
        if (toastTimer) {
            clearTimeout(toastTimer);
            toastTimer = null;
        }

        toast.textContent = message;
        toast.className = 'feedback-toast ' + type;
        // Force reflow
        toast.offsetHeight;
        toast.classList.add('show');

        // Tự động ẩn sau 3.5s
        toastTimer = setTimeout(() => {
            toast.classList.remove('show');
            toast.classList.add('hide');
            setTimeout(() => {
                toast.classList.remove('hide');
                toast.className = 'feedback-toast';
            }, 300);
        }, 3500);
    }

    options.forEach(opt => {
        opt.addEventListener('touchstart', () => {
            if (!isAnswered) opt.classList.add('touching');
        }, { passive: true });

        opt.addEventListener('touchend', () => {
            opt.classList.remove('touching');
        }, { passive: true });

        opt.addEventListener('click', async function() {
            if (isAnswered) return;

            const selectedOpt = this.dataset.option;
            isAnswered = true;
            this.classList.add('selected');
            options.forEach(o => o.classList.add('disabled'));
            optionsGrid.style.opacity = '0.8';

            try {
                const response = await fetch('@Url.Action("SubmitAnswer", "Quiz")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': afToken
                    },
                    body: JSON.stringify({
                        SessionId: @Model.SessionId,
                        QuestionId: @Model.QuestionId,
                        SelectedOption: selectedOpt
                    })
                });

                if (!response.ok) {
                    let errMsg = 'Network response was not ok';
                    try {
                        const errData = await response.json();
                        errMsg = errData.details || errData.error || errMsg;
                    } catch (e) {}
                    throw new Error(errMsg);
                }

                const result = await response.json();
                optionsGrid.style.opacity = '1';
                this.classList.remove('selected');

                if (result.isCorrect) {
                    this.classList.add('correct');
                    const toastMsg = currentLang === 'vi' 
                        ? '🎉 Chính xác! +' + result.pointsEarned + ' điểm' 
                        : '🎉 Correct! +' + result.pointsEarned + ' points';
                    showToast(toastMsg, 'correct');
                } else {
                    this.classList.add('wrong');
                    const correctEl = document.querySelector(`.answer-option[data-option="${result.correctOption}"]`);
                    if (correctEl) correctEl.classList.add('correct');
                    const toastMsg = currentLang === 'vi'
                        ? '❌ Sai rồi! Đáp án đúng là ' + result.correctOption
                        : '❌ Incorrect! Correct option is ' + result.correctOption;
                    showToast(toastMsg, 'wrong');
                }

                lastPoints = result.newTotalScore;
                updateDynamicElements();

                if (result.isLastQuestion) {
                    nextUrl = '@Url.Action("FinishQuiz", "Quiz")';
                    isLast = true;
                    updateDynamicElements();
                }

                // Hiện nút Tiếp tục (cố định dưới màn hình)
                bottomAction.style.display = 'block';

            } catch (error) {
                console.error('Error submitting answer:', error);
                alert('Lỗi: ' + error.message);
                isAnswered = false;
                optionsGrid.style.opacity = '1';
                this.classList.remove('selected');
                options.forEach(o => o.classList.remove('disabled'));
            }
        });
    });

    btnNext.addEventListener('click', function() {
        this.disabled = true;
        this.innerHTML = '<span class="spinner"></span>';
        window.location.href = nextUrl;
    });

    // Initial sync
    updateDynamicElements();
});
</script>
}
