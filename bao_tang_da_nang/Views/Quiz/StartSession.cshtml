@model StartSessionViewModel
@{
    ViewData["Title"] = "Bắt đầu phiên chơi";

    // Mô tả cho từng đề tài
    string GetTopicDescription(string topic)
    {
        var upper = topic.ToUpper();
        if (upper.Contains("ĐỀ TÀI 1") || upper.Contains("TỔNG QUAN")) return "Khám phá vị trí địa lý, lịch sử hình thành và các công trình kiến trúc độc đáo của Bảo tàng Đà Nẵng.";
        if (upper.Contains("ĐỀ TÀI 2") || upper.Contains("SINH THÁI RỪNG")) return "Tìm hiểu về hệ sinh thái rừng phong phú, các loài động thực vật quý hiếm và khí hậu đặc trưng của Đà Nẵng.";
        if (upper.Contains("ĐỀ TÀI 3") || upper.Contains("ĐỊA CHẤT")) return "Khám phá cấu trúc địa chất kỳ thú, tài nguyên khoáng sản và hệ sinh thái biển đa dạng của vùng biển Đà Nẵng.";
        if (upper.Contains("ĐỀ TÀI 4") || upper.Contains("SA HUỲNH") || upper.Contains("TIỀN - SƠ SỬ")) return "Hành trình ngược thời gian về thời kỳ tiền sử, khám phá những bí ẩn của nền văn hóa Sa Huỳnh huyền bí.";
        if (upper.Contains("ĐỀ TÀI 5") || upper.Contains("CHAMPA")) return "Tìm hiểu những dấu ấn văn hóa Champa qua hệ thống đền tháp, văn bia chữ Phạn và giếng cổ độc đáo.";
        if (upper.Contains("ĐỀ TÀI 6")) return "Khám phá Đà Nẵng từ thế kỷ XV đến trước năm 1858 — thời kỳ Đại Việt với nhiều biến cố lịch sử quan trọng.";
        if (upper.Contains("ĐỀ TÀI 7")) return "Tìm hiểu Đà Nẵng dưới thời Pháp thuộc và phong trào yêu nước, kháng chiến của nhân dân địa phương.";
        if (upper.Contains("ĐỀ TÀI 8")) return "Những trang sử hào hùng của Đà Nẵng trong cuộc kháng chiến chống Mỹ cứu nước.";
        if (upper.Contains("ĐỀ TÀI 9")) return "Khám phá văn hóa dân gian, phong tục tập quán và đời sống tinh thần phong phú của người dân Đà Nẵng.";
        if (upper.Contains("ĐỀ TÀI 10")) return "Đà Nẵng trên con đường đổi mới và hội nhập — từ thành phố chiến tranh đến đô thị năng động hiện đại.";
        if (upper.Contains("TỔNG HỢP 300")) return "Bộ 300 câu hỏi tổng hợp toàn diện bao phủ tất cả các chủ đề về Bảo tàng và lịch sử Đà Nẵng.";
        return "Khám phá những câu hỏi thú vị về lịch sử, văn hóa và thiên nhiên Đà Nẵng.";
    }

    string GetTopicDescriptionTranslationKey(string topic)
    {
        var upper = topic.ToUpper();
        if (upper.Contains("ĐỀ TÀI 1") || upper.Contains("TỔNG QUAN")) return "topic_desc_1";
        if (upper.Contains("ĐỀ TÀI 2") || upper.Contains("SINH THÁI RỪNG")) return "topic_desc_2";
        if (upper.Contains("ĐỀ TÀI 3") || upper.Contains("ĐỊA CHẤT")) return "topic_desc_3";
        if (upper.Contains("ĐỀ TÀI 4") || upper.Contains("SA HUỲNH") || upper.Contains("TIỀN - SƠ SỬ")) return "topic_desc_4";
        if (upper.Contains("ĐỀ TÀI 5") || upper.Contains("CHAMPA")) return "topic_desc_5";
        if (upper.Contains("ĐỀ TÀI 6")) return "topic_desc_6";
        if (upper.Contains("ĐỀ TÀI 7")) return "topic_desc_7";
        if (upper.Contains("ĐỀ TÀI 8")) return "topic_desc_8";
        if (upper.Contains("ĐỀ TÀI 9")) return "topic_desc_9";
        if (upper.Contains("ĐỀ TÀI 10")) return "topic_desc_10";
        if (upper.Contains("TỔNG HỢP 300")) return "topic_desc_300";
        return "topic_desc_general";
    }

    string GetTopicTranslationKey(string topicName)
    {
        if (string.IsNullOrEmpty(topicName)) return "";
        string upper = topicName.ToUpper();
        if (upper.Contains("TỔNG HỢP 1")) return "topic_tonghop_1";
        if (upper.Contains("TỔNG HỢP 2")) return "topic_tonghop_2";
        if (upper.Contains("TỔNG HỢP 3")) return "topic_tonghop_3";
        if (upper.Contains("TỔNG HỢP 4")) return "topic_tonghop_4";
        if (upper.Contains("TỔNG HỢP 300")) return "topic_desc_300";
        if (upper.Contains("ĐỀ TÀI 1") || upper.Contains("ĐỊA LÝ")) return "topic_chude_1";
        if (upper.Contains("ĐỀ TÀI 2") || upper.Contains("THIÊN NHIÊN")) return "topic_chude_2";
        if (upper.Contains("ĐỀ TÀI 3") || upper.Contains("ĐỊA CHẤT")) return "topic_chude_3";
        if (upper.Contains("ĐỀ TÀI 4") || upper.Contains("TIỀN - SƠ SỬ")) return "topic_chude_4";
        return "topic_general";
    }

    var topicDesc = GetTopicDescription(Model.Topic);
    var topicDescKey = GetTopicDescriptionTranslationKey(Model.Topic);
    var topicKey = GetTopicTranslationKey(Model.Topic);
    int maxQuestions = Model.Topic.StartsWith("Tổng hợp", StringComparison.OrdinalIgnoreCase) ? 100 : 30;
    int stepCount = maxQuestions == 100 ? 10 : 5;
}

@section Styles {
    <style>
        .footer-quizkid { display: none !important; }

        /* Slider tùy chỉnh */
        .question-count-slider {
            -webkit-appearance: none;
            appearance: none;
            width: 100%;
            height: 8px;
            border-radius: 10px;
            background: linear-gradient(to right, #D4AF37 0%, #D4AF37 var(--slider-percent, 100%), #EBEAE5 var(--slider-percent, 100%), #EBEAE5 100%);
            outline: none;
            cursor: pointer;
        }
        .question-count-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: #D4AF37;
            cursor: pointer;
            border: 4px solid white;
            box-shadow: 0 4px 12px rgba(212, 175, 55, 0.5);
            transition: transform 0.15s ease;
        }
        .question-count-slider::-webkit-slider-thumb:hover {
            transform: scale(1.2);
        }
        .question-count-slider::-moz-range-thumb {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: #D4AF37;
            cursor: pointer;
            border: 4px solid white;
            box-shadow: 0 4px 12px rgba(212, 175, 55, 0.5);
        }

        .topic-desc-box {
            background: linear-gradient(135deg, #FFF9E6, #FFF3CC);
            border: 2px solid #F6E2A3;
            border-radius: 20px;
            padding: 14px 18px;
            font-size: 0.92rem;
            color: #705A1A;
            font-weight: 600;
            line-height: 1.6;
        }
        .topic-desc-box .topic-icon {
            font-size: 1.4rem;
            margin-right: 8px;
            vertical-align: middle;
        }

        .count-pills {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-top: 12px;
        }
        .count-pill {
            padding: 6px 16px;
            border-radius: 50px;
            border: 2px solid #EBEAE5;
            font-weight: 700;
            font-size: 0.85rem;
            color: #805A12;
            cursor: pointer;
            background: white;
            transition: all 0.2s ease;
        }
        .count-pill:hover, .count-pill.active {
            background: #D4AF37;
            border-color: #D4AF37;
            color: white;
        }

        .count-display {
            font-family: var(--font-heading, 'Nunito', sans-serif);
            font-weight: 900;
            font-size: 2rem;
            color: #D4AF37;
        }

        /* Responsive Mobile Settings */
        @@media (max-width: 768px) {
            .kid-quiz-card {
                padding: 24px !important;
            }
            .kid-title {
                font-size: 1.8rem !important;
            }
            .count-pills {
                justify-content: center;
            }
        }
    </style>
}

<div class="kid-quiz-page animate-fadeInUp" style="padding-top: 30px; padding-bottom: 60px;">
    <div class="text-center mb-4">
        <img src="~/images/lightbulb_mascot.png" alt="Lightbulb Mascot"
             style="width: 120px; height: 120px; border-radius: 20px; object-fit: cover; box-shadow: 0 10px 20px rgba(0,0,0,0.15); margin-bottom: -10px; position: relative; z-index: 10;" />
        <br />
        <div class="kid-eyebrow d-inline-block"
             style="background-color: #FA9465; color: white; padding: 6px 16px; border-radius: 20px; font-size: 0.75rem; font-weight: 800; letter-spacing: 0.5px; position: relative; z-index: 11; border: 2px solid white;"
             data-translate="start_session_eyebrow">
            <i class="fa-solid fa-magnifying-glass"></i> SẴN SÀNG KHÁM PHÁ
        </div>
        <h1 class="kid-title mt-3"
            style="font-family: var(--font-heading); font-weight: 900; font-size: 2.4rem; color: #2C2825;"
            data-translate="start_session_header">Chơi quiz cùng Bảo tàng</h1>
    </div>

    <div class="kid-quiz-card"
         style="max-width: 600px; margin: 0 auto; background: white; border-radius: 30px; padding: 36px; box-shadow: 0 20px 40px rgba(0,0,0,0.08); position: relative;">
        <div style="position: absolute; top: -15px; right: -15px; width: 40px; height: 40px; background-color: #FA9465; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; border: 3px solid white; box-shadow: 0 4px 10px rgba(250, 148, 101, 0.4); font-size: 1.2rem;">
            <i class="fa-solid fa-star"></i>
        </div>

        @if (TempData["ErrorMessage"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger rounded-4 fw-bold" role="alert">
                <i class="fa-solid fa-triangle-exclamation"></i> @errorMessage
            </div>
        }

        <!-- Đề tài đã chọn + mô tả -->
        <div class="mb-4">
            <div style="font-size: 0.75rem; color: #A27D42; margin-bottom: 8px; font-weight: 800; text-transform: uppercase;"
                 data-translate="start_session_chosen_topic">
                Đề tài đã chọn
            </div>
            <div style="padding: 14px 18px; border: 2px solid #F6E2A3; border-radius: 20px; font-weight: 700; color: #805A12; font-size: 1rem; display: flex; align-items: center; gap: 10px; margin-bottom: 12px;">
                <i class="fa-solid fa-scroll"></i>
                <span data-translate="@topicKey">@Model.Topic</span>
            </div>
            <div class="topic-desc-box">
                <span class="topic-icon">💡</span><span data-translate="@topicDescKey">@topicDesc</span>
            </div>
        </div>

        <form asp-action="StartSession" asp-controller="Quiz" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Topic" />
            <input type="hidden" name="QuestionCount" id="hiddenQuestionCount" value="@maxQuestions" />

            <!-- Tên người chơi -->
            <div class="mb-4">
                <label asp-for="PlayerName" class="form-label"
                       style="font-size: 0.75rem; font-weight: 800; color: #A27D42; text-transform: uppercase;"
                       data-translate="start_session_label">Tên người chơi</label>
                <div style="position: relative;">
                    <input asp-for="PlayerName" class="form-control shadow-none" placeholder="Nhập tên của em..."
                           data-translate="start_session_placeholder" autocomplete="name"
                           style="padding: 16px 20px; border-radius: 50px; background-color: #F5F4F0; border: 2px solid #EBEAE5; font-weight: 600; color: #504C49; font-size: 1.05rem; padding-right: 45px;" />
                    <i class="fa-solid fa-pencil"
                       style="position: absolute; right: 20px; top: 50%; transform: translateY(-50%); color: #B5B2AB;"></i>
                </div>
                <span asp-validation-for="PlayerName" class="text-danger mt-2 d-block" style="font-size: 0.9rem; font-weight: 700;"></span>
            </div>

            <!-- Chọn số câu hỏi -->
            <div class="mb-5">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                    <div style="font-size: 0.75rem; font-weight: 800; color: #A27D42; text-transform: uppercase;" data-translate="start_session_question_count_label">
                        🎯 Số câu hỏi
                    </div>
                    <div>
                        <span class="count-display" id="countDisplay">@maxQuestions</span>
                        <span style="font-size: 0.85rem; color: #A27D42; font-weight: 700;" data-translate="start_session_question_unit"> câu</span>
                    </div>
                </div>

                @if (maxQuestions == 100)
                {
                    <div style="padding: 16px; background-color: #F5F4F0; border-radius: 20px; border: 2px solid #EBEAE5; text-align: center; color: #805A12; font-weight: 700; font-size: 0.95rem;">
                        <i class="fa-solid fa-lock" style="margin-right: 5px;"></i> <span data-translate="start_session_fixed_100">Chủ đề này thi cố định 100 câu hỏi tổng hợp.</span>
                    </div>
                    <input type="hidden" id="questionCountSlider" value="100" />
                }
                else
                {
                    <input type="range" class="question-count-slider" id="questionCountSlider"
                           min="10" max="@maxQuestions" step="@stepCount" value="@maxQuestions"
                           oninput="updateCount(this.value)" />

                    <div class="count-pills" id="countPills">
                        <span class="count-pill" onclick="setCount(10)"><span data-translate="start_session_pill_10">10 câu</span></span>
                        <span class="count-pill" onclick="setCount(15)"><span data-translate="start_session_pill_15">15 câu</span></span>
                        <span class="count-pill" onclick="setCount(20)"><span data-translate="start_session_pill_20">20 câu</span></span>
                        <span class="count-pill active" onclick="setCount(30)"><span data-translate="start_session_pill_30">30 câu (Tất cả)</span></span>
                    </div>
                    <div style="margin-top: 8px; font-size: 0.8rem; color: #A27D42; font-weight: 600;" data-translate="start_session_fairness_hint">
                        💡 Điểm được tính theo % chính xác — <strong>10 hay 30 câu đều công bằng như nhau!</strong>
                    </div>
                }
            </div>

            <!-- Nút bắt đầu -->
            <div class="d-grid gap-3">
                <button type="submit" class="btn"
                        style="background: linear-gradient(180deg, #F9B621 0%, #E89100 100%); color: white; padding: 18px; border-radius: 50px; font-weight: 800; font-size: 1.2rem; border: none; box-shadow: 0 10px 20px rgba(232, 145, 0, 0.3), inset 0 -4px 0 rgba(0,0,0,0.1); display: flex; align-items: center; justify-content: center; gap: 10px; transition: transform 0.2s ease;"
                        data-translate="start_session_btn">
                    <i class="fa-solid fa-rocket"></i> BẮT ĐẦU NGAY
                </button>
                <a asp-controller="Home" asp-action="Index" class="btn text-center"
                   style="background-color: #EBEAE5; color: #504C49; padding: 14px; border-radius: 50px; font-weight: 700; text-decoration: none; border: none; display: flex; align-items: center; justify-content: center; gap: 8px; transition: background-color 0.2s ease;"
                   data-translate="start_session_back">
                    <i class="fa-solid fa-house"></i> Quay lại trang chủ
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const slider = document.getElementById('questionCountSlider');
        const countDisplay = document.getElementById('countDisplay');
        const hiddenCount = document.getElementById('hiddenQuestionCount');
        const pills = document.querySelectorAll('.count-pill');

        function updateCount(val) {
            val = parseInt(val);
            if (countDisplay) countDisplay.textContent = val;
            if (hiddenCount) hiddenCount.value = val;
            
            // Update slider gradient if it's a range input
            if (slider && slider.type === 'range') {
                const min = parseInt(slider.min), max = parseInt(slider.max);
                const pct = ((val - min) / (max - min)) * 100;
                slider.style.setProperty('--slider-percent', pct + '%');
            }
            
            // Sync pills
            pills.forEach(p => {
                p.classList.toggle('active', parseInt(p.textContent) === val || 
                    (p.textContent.includes('Tất cả') && val === 30) ||
                    (p.textContent.includes('Tất cả') && val === 100));
            });
        }

        function setCount(val) {
            slider.value = val;
            updateCount(val);
        }

        // Init
        updateCount(@maxQuestions);
    </script>
}
